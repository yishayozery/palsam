// PALMY — מערכת ניהול מלאי גדודי (v2)
// רב-דיירים (Multi-Tenant): אדמין-על מקים גדודים; כל גדוד מבודד לוגית לפי battalionId.
// 4 מחסנים מטופסים (ציוד/תקשוב/חמידה/ארמון), מידוף (מחסן/עמודה/שורה), Admin-driven.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== Enums =====================

enum Role {
  SUPER_ADMIN // אדמין-על (גלובלי, ללא גדוד) — מקים גדודים ומפמ"ים
  BATTALION_ADMIN // מפמ — אחראי מערכת בגדוד
  WAREHOUSE_MANAGER // מנהל מחסן (קל"ג/קשר"ג/בונקר/ארמון) — לפי המחסן שלו
  COMPANY_REP // נציג פלוגה
  VIEWER // צופה — קריאה בלבד ברמת גדוד
  SHALISH // שליש גדודי — ניהול חיילים + אישור גיוס (שלישות)
  MAGAD // מג"ד - מפקד הגדוד. צפייה מלאה + אישור חיילים לחימוש.
  SAMAGAD // סמג"ד - סגן מפקד הגדוד. אותן הרשאות כמו מג"ד.
}

enum HolderKind {
  WAREHOUSE // מחסן גדודי (טיפוסו ב-warehouseType)
  COMPANY // פלוגה
}

enum WarehouseType {
  EQUIPMENT // ציוד (קל"ג)
  COMMS // תקשוב (קשר"ג)
  AMMO // חמידה / תחמושת (בונקר)
  ARMORY // ארמון
  VEHICLES // רכבים (קצין רכב)
  MEDICAL // רפואה
  GENERAL // כללי
}

enum TrackingMethod {
  QUANTITY
  SERIAL
  LOT
  KIT
}

enum TransferType {
  INTAKE // קליטת מלאי חדש (מהחטיבה)
  WRITE_OFF // גריעת מלאי (לחטיבה)
  ISSUE // ניפוק: מחסן ◄ פלוגה
  RETURN // החזרה: פלוגה ◄ מחסן
  SIGNOUT // החתמת חייל
  CHECKIN // זיכוי חייל
  EXTERNAL_OUT // החתמת חוץ — מסירת ציוד לגורם חיצוני (מכל מחסן)
  EXTERNAL_IN // זיכוי חוץ — קבלת ציוד חזרה מגורם חיצוני
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum SignatureMethod {
  LINK
  QR
  ONSITE
}

enum SignatureStatus {
  PENDING
  SIGNED
  EXPIRED
  CANCELED
}

enum CountType {
  WAREHOUSE
  COMPANY
  GLOBAL
}

enum CountScope {
  WAREHOUSE_STOCK
  DISTRIBUTED
  BOTH
}

enum CountSessionStatus {
  DRAFT
  FROZEN
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum CountTaskStatus {
  SCHEDULED      // עתידי
  PENDING        // פתוח, ממתין לדיווח
  IN_PROGRESS    // התחיל לדווח
  COMPLETED      // הושלם
  OVERDUE        // עבר הזמן ולא דווח
  CANCELED
}

enum DiscrepancyKind {
  LOSS
  SURPLUS
  STATUS_MISMATCH
}

enum DiscrepancyStatus {
  OPEN
  RESOLVED
}

// ===================== דייר: גדוד =====================

model Battalion {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  brigade   String? // חטיבה (לשרשור שמות משתמש)
  commander String? // מפקד הגדוד (פרופיל)
  motto     String? // משפט/סיסמת הגדוד (לדוגמה: "לנצח בכל מחיר")
  notes     String?
  logoData  String? // סמל הגדוד (data-URL)
  active    Boolean  @default(true)
  // הגדרות גדוד
  requirePersonalIdOnHandover Boolean @default(false) // לחייב מספר אישי בכל מסירה
  senderEmail                 String? // כתובת שליחה לגדוד (למשל gadsam@palmy.co.il). ברירת מחדל: EMAIL_FROM מ-env
  notificationEmail           String? // אם מוגדר → מייל אוטומטי על כל פעולה מבצעית (חתימה/זיכוי/מסירה/שיבוץ)
  emailToBattalion            Boolean @default(true) // האם לשלוח התראות גם למייל הגדוד (בנוסף למחסן/פלוגה)
  armoryTestUrl               String? // קישור למבחן נוהל ארמון חיצוני (אם יש)
  drivingRefreshDays          Int     @default(180) // ימי תוקף ריענון נהיגה
  defaultDelegateCap          Int     @default(2) // תקרת ברירת מחדל לרספ"ים/סגנים ליחידה (Holder.delegateCap גובר)
  supportWhatsapp             String? // מספר ווטסאפ תמיכה לגדוד זה (בינ"ל, גובר על ההגדרה הגלובלית)
  attendanceReminderEnabled   Boolean @default(false) // תזכורת בוקר אוטומטית לדיווח נוכחות
  attendanceReminderText      String? // טקסט מותאם לתזכורת (אופציונלי)
  attendanceDeadline          String? // שעת גג לדיווח נוכחות (HH:mm) — תזכורת חוזרת חצי שעה לפני
  attendanceInitialSentOn     String? // YYYY-MM-DD (שעון ישראל) — נשלחה תזכורת פתיחה היום (מונע כפילות)
  attendanceFollowupSentOn    String? // YYYY-MM-DD — נשלחה תזכורת חוזרת היום (מונע כפילות)
  attendanceReportWindowDow   Json?   // 7 מספרים (א׳..שבת) — כמה ימים קדימה מותר לדווח בכל יום בשבוע
  attendanceReportOverrides   AttendanceReportOverride[]
  vehicleFuelCards            VehicleFuelCard[]
  vehicleLinks                VehicleLink[]
  vehicleMaintenances         VehicleMaintenance[]
  botNotificationRules        BotNotificationRule[]
  vehicleFaults               VehicleFault[]
  vehicleFaultCategories      VehicleFaultCategory[]
  tripLink                    String? // קישור "פתיחת משימת נסיעה" שנשלח לנהגים בבוט עם השיבוץ למשימה
  drivingProcedureText        String? // נוסח נוהל נהיגה לחתימת נהגים (מוצג בבוט + קצין רכב)
  drivingProcedureUpdatedAt   DateTime? // מתי עודכן הנוסח — חתימה מלפני התאריך נחשבת לא-תקפה (גרסה חדשה → חתימה מחדש)
  driverFormValidities        DriverFormValidity[] // תוקף פר-סוג-טופס בתיק נהג
  driverForms                 DriverForm[] // טפסי תיק נהג בגדוד
  telegramBotToken            String? // טוקן בוט טלגרם לשליחת הודעות אוטומטיות
  telegramBotInfo             String? // מידע כללי שהבוט ישלח (ארוחות, תפילות, טלפונים)
  telegramBotUsername         String? // username של הבוט (מתעדכן אוטומטית ברישום webhook)
  soldierDepartureMessage     String? // הודעה חופשית שנשלחת לחייל ביציאה/חופשה דרך הבוט
  // תנאי חתימת נשק — הגדוד קובע אילו שלבים חובה לפני החתמה על נשק
  requireEnlistment       Boolean @default(true) // שלישות חובה
  requireWeaponsApproval  Boolean @default(true) // אישור מגד/סמגד חובה
  requireArmoryTest       Boolean @default(true) // מבחן נוהל ארמון חובה
  requireWeaponsAgreement Boolean @default(true) // חתימה על נוהל שמירת נשק חובה
  createdAt DateTime @default(now())

  users         AppUser[]
  customRoles   CustomRole[]
  holders       Holder[]
  soldiers      Soldier[]
  categories    Category[]
  statuses      ItemStatus[]
  frequencies   CountFrequency[]
  itemTypes     ItemType[]
  stockBalances StockBalance[]
  soldierItemLocations SoldierItemLocation[]
  companyItemBaselines CompanyItemBaseline[] @relation("BattalionBaselines")
  shiftHandovers       ShiftHandover[]
  supportQuestions     SupportQuestion[]     @relation("BattalionSupport")
  companyAllocations   CompanyAllocation[]  @relation("BattalionAllocations")
  vehicleAssignments   VehicleAssignment[] @relation("BattalionDispatch")
  missions             Mission[]           @relation("BattalionMissions")
  serialUnits   SerialUnit[]
  kitInstances  KitInstance[]
  transfers     Transfer[]
  signatures    Signature[]
  countDefs     CountDefinition[]
  countPlans    CountPlan[]
  countTasks    CountTask[]
  countSessions CountSession[]
  discrepancies Discrepancy[]
  auditLogs     AuditLog[]
  equipmentLocations EquipmentLocation[]
  squads             Squad[]
  companyRoles       CompanyRole[]
  attendanceStatuses AttendanceStatus[]
  attendanceLocks    AttendanceLock[] @relation("BattalionAttendanceLocks")
  vacationBoards     VacationBoard[]
  vacationStatuses   VacationStatus[]
  armoryInspections    ArmoryInspection[]
  armoryChecklistItems ArmoryChecklistItem[]
  // 🏛️ היררכיית יחידה — גדוד/חטיבה כאותה ישות. level=BRIGADE + parentId=null = חטיבה;
  //    level=BATTALION + parentId=<חטיבה> = גדוד המשויך לחטיבה.
  level              UnitLevel   @default(BATTALION)
  parentId           String?
  parent             Battalion?  @relation("UnitHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children           Battalion[] @relation("UnitHierarchy")
  requestsOpened     Request[]   @relation("RequestOpener")
  requestsReceived   Request[]   @relation("RequestTarget")
  dutyBoards         DutyBoard[]
  dispatchRoles      DispatchRole[] @relation("BattalionDispatchRoles")
  dispatchTemplates  DispatchTemplate[] @relation("BattalionDispatchTemplates")
  drivingLicenseTypes DrivingLicenseType[] @relation("BattalionDrivingLicenseTypes")
  systemRoles        SystemRole[]      @relation("BattalionSystemRoles")
  employments        Employment[]
  certificationTypes CertificationType[] @relation("BattalionCertificationTypes")
  scheduleEvents         ScheduleEvent[]
  attachmentRequests     AttachmentRequest[]
  companyWarehouses      CompanyWarehouse[]  @relation("BattalionCompanyWarehouses")
  operationalKits        OperationalKit[]    @relation("BattalionOpKits")
  ymachGaps              YmachGap[]          @relation("BattalionYmachGaps")
  verificationRequests   VerificationRequest[] @relation("BattalionVerifications")
  dispatchTokens         DispatchToken[]       @relation("BattalionDispatchTokens")
}

// ===================== משתמשים =====================

model AppUser {
  id           String     @id @default(cuid())
  username     String
  passwordHash String
  fullName     String
  phone        String? // לשליחת הזמנה בוואטסאפ
  title        String? // תואר/תפקיד טקסט חופשי (מפ, רס"פ, מפקד מחסן, אחראי, מפלג, וכו')
  role         Role       // legacy — נשמר לתאימות לאחור
  systemRoleId String?
  systemRole   SystemRole? @relation(fields: [systemRoleId], references: [id])
  customRoleId String?
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  passwordSet  Boolean    @default(true) // false עד הגדרת סיסמה דרך קישור ההזמנה
  // 🔫 הרשאה פר-משתמש לאשר חיילים לנשק (לא לפי תפקיד) — נקבע בהקמת/עריכת משתמש
  canApproveWeapons Boolean @default(false)
  inviteToken  String?    @unique
  magicToken    String?   @unique // לינק כניסה חד-פעמי מהבוט (קצר-מועד)
  magicTokenExp DateTime? // תפוגת ה-magicToken
  loginCode     String?   // קוד כניסה נוסף (נבדק בשדה "מספר גדוד") — למשל לאדמין-על שאין לו גדוד
  battalionId  String? // null עבור SUPER_ADMIN
  battalion    Battalion? @relation(fields: [battalionId], references: [id])
  // המחזיק הראשי: פלוגה (COMPANY_REP) או מחסן ראשי (WAREHOUSE_MANAGER)
  holderId     String?
  holder       Holder?    @relation("HolderUsers", fields: [holderId], references: [id])
  // שיוך לכמה מחסנים (קצין שמנהל יותר ממחסן אחד)
  assignedHolders UserHolder[]
  // קישור לרוסטר השלישות — המשתמש הזה הוא גם חייל בגדוד
  soldierId    String?    @unique
  soldier      Soldier?   @relation("SoldierAsUser", fields: [soldierId], references: [id])
  active       Boolean    @default(true)
  // 🔐 2FA TOTP (Google Authenticator) — אופציונלי, מומלץ לאדמינים
  totpSecret   String? // base32 secret, מוצפן בעתיד
  totpEnabledAt DateTime? // נקבע ברגע ההפעלה
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  createdTransfers  Transfer[]         @relation("TransferCreatedBy")
  approvedTransfers Transfer[]         @relation("TransferApprovedBy")
  recipientTransfers Transfer[]        @relation("TransferToUser")
  signedAsUser      Signature[]        @relation("SignerUser")
  createdDispatches VehicleAssignment[] @relation("DispatchCreatedBy")
  createdMissions   Mission[]           @relation("MissionCreatedBy")
  createdDispatchTemplates DispatchTemplate[] @relation("DispatchTemplateCreatedBy")
  startedCounts     CountSession[]     @relation("CountStartedBy")
  createdCountPlans CountPlan[]        @relation("CountPlanCreatedBy")
  responsibleCountPlans CountPlan[]    @relation("CountPlanResponsible")
  assignedCountTasks CountTask[]       @relation("CountTaskAssigned")
  resolvedGaps      Discrepancy[]      @relation("DiscrepancyResolvedBy")
  auditLogs         AuditLog[]
  repOfCompanies    WarehouseCompany[] @relation("RepUser")
  assignedSquads    UserSquad[]
  vacationAssignees VacationAssignee[]
  vacationEntries   VacationEntry[]
  scheduleForces    ScheduleForce[]  @relation("ScheduleForceUser")
  scheduleApprovals ScheduleApprover[] @relation("ScheduleApproverUser")
  attachmentRequested   AttachmentRequest[]    @relation("AttachmentRequestedBy")
  attachmentStatusLogs  AttachmentStatusLog[]  @relation("AttachmentStatusChanged")

  // שם משתמש ייחודי בתוך הגדוד (ולא גלובלית) — פלוגה בגדוד א' יכולה להיות עם אותו שם משתמש כמו בגדוד ב'
  // אדמין-על (battalionId=null): Postgres מתייחס ל-null כשונה, לכן ייחודיות נאכפת ידנית עבורם
  @@unique([battalionId, username])
}

// ===================== תפקידים =====================
// תפקיד גמיש ברמת גדוד — מחליף את ה-Role enum הקשיח
model SystemRole {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation("BattalionSystemRoles", fields: [battalionId], references: [id])
  name        String    // מפ, קשר"ג, מג"ד, ...
  isPreset    Boolean   @default(false) // תפקיד מובנה (לא ניתן למחיקה)
  isAdmin     Boolean   @default(false) // גישה מלאה למערכת
  isCommander Boolean   @default(false) // תפקיד פיקודי (מפ, מג"ד, סמג"ד)
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  permissions ScreenPermission[]
  users       AppUser[]

  @@unique([battalionId, name])
  @@index([battalionId])
}

enum PermissionLevel {
  VIEW
  EDIT
}

model ScreenPermission {
  id     String          @id @default(cuid())
  roleId String
  role   SystemRole      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  screen String          // מפתח מסך: soldiers, stock, dispatch, ...
  level  PermissionLevel // צפייה / עריכה

  @@unique([roleId, screen])
}

// Legacy — נשמר לתאימות לאחור עד מיגרציה מלאה
model CustomRole {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id])
  name        String
  template    Role
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  users AppUser[]

  @@unique([battalionId, name])
}

// ערכת החתמה — מוגדרת ברמת מחזיק (פלוגה/מחסן) ומשמשת בהחתמת חייל
model SignableKit {
  id          String            @id @default(cuid())
  battalionId String
  holderId    String // הפלוגה/מחסן שהקים את הערכה
  holder      Holder            @relation("SignableKitHolder", fields: [holderId], references: [id])
  name        String
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  lines       SignableKitLine[]

  @@unique([holderId, name])
}

model SignableKitLine {
  id         String      @id @default(cuid())
  kitId      String
  kit        SignableKit @relation(fields: [kitId], references: [id], onDelete: Cascade)
  itemTypeId String
  itemType   ItemType    @relation("KitLineItem", fields: [itemTypeId], references: [id])
  quantity   Int         @default(1)
}

// שיוך משתמש למחסן (תמיכה בכמה מחסנים לקצין אחד)
model UserHolder {
  id       String  @id @default(cuid())
  userId   String
  user     AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  holderId String
  holder   Holder  @relation(fields: [holderId], references: [id])

  @@unique([userId, holderId])
}

model UserSquad {
  id      String  @id @default(cuid())
  userId  String
  user    AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  squadId String
  squad   Squad   @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([userId, squadId])
  @@index([userId])
}

// ===================== מחזיקים: מחסנים ופלוגות =====================

model Holder {
  id            String         @id @default(cuid())
  battalionId   String
  battalion     Battalion      @relation(fields: [battalionId], references: [id])
  kind          HolderKind
  warehouseType WarehouseType? // רק למחסנים
  name          String
  code          String?
  active        Boolean        @default(true)
  // 📝 תניית חתימה (text חופשי) - מוצגת ב-/sign/[token] וב-PDF כשמחתימים מהמחסן הזה
  signatureClause String?
  // 🔫 נוהל שמירת נשק (טקסט חופשי) — לארמון. אם ריק, נוסח ברירת מחדל
  weaponsAgreementText String?
  armoryTestUrl        String?
  notificationEmails   String?  // כתובות מייל להתראות (מופרדות בפסיקים)
  delegateCap   Int?           // תקרת רספ"ים/סגנים שאפשר למנות ל-Holder זה (null = ברירת מחדל 2)
  createdAt     DateTime       @default(now())

  users            AppUser[]          @relation("HolderUsers")
  assignedUsers    UserHolder[]
  soldiers         Soldier[]
  storageLocations StorageLocation[]
  itemHolderLocations ItemHolderLocation[]
  equipmentLocations EquipmentLocation[]
  // סמל פלוגה / מחסן (אופציונלי) — מוצג בסיידבר לצד סמל הגדוד
  logoData String?
  stockBalances    StockBalance[]
  serialUnits      SerialUnit[]       @relation("SerialUnitHolder")
  kitInstances     KitInstance[]      @relation("KitInstanceHolder")
  transfersFrom    Transfer[]         @relation("TransferFrom")
  transfersTo      Transfer[]         @relation("TransferTo")
  countDefs        CountDefinition[] @relation("CountDefHolder")
  countTasks       CountTask[]
  countLines       CountLine[]
  secondarySoldiers Soldier[]        @relation("SoldierSecondary")
  discrepancies    Discrepancy[]
  companyItemBaselines CompanyItemBaseline[] @relation("HolderBaselines")
  shiftHandovers       ShiftHandover[]       @relation("HolderShiftHandovers")
  companyAllocations   CompanyAllocation[]  @relation("HolderAllocations")
  courseAllocations    CourseAllocation[]   @relation("HolderCourseAllocations")
  courseRequests       CourseRequest[]      @relation("HolderCourseRequests")
  soldierIndexes       WarehouseSoldierIndex[] @relation("HolderSoldierIndex")
  squads               Squad[]
  companyRoles         CompanyRole[]
  dispatchAssignments  VehicleAssignment[] @relation("CompanyDispatch")
  companyMissions      Mission[]           @relation("CompanyMissions")
  dispatchTemplates    DispatchTemplate[]  @relation("DispatchTemplateCompany")
  attendanceLocks      AttendanceLock[]    @relation("CompanyAttendanceLocks")
  // קשרי מחסן↔פלוגה (איזה פלוגות המחסן עובד מולן)
  warehouseLinks   WarehouseCompany[] @relation("WarehouseSide")
  companyLinks     WarehouseCompany[] @relation("CompanySide")
  ownedDonations   ItemType[]         @relation("ItemOwnerHolder")
  signableKits     SignableKit[]      @relation("SignableKitHolder")
  employmentAllocations EmploymentAllocation[] @relation("CompanyEmploymentAllocations")
  attachmentRequests    AttachmentRequest[]    @relation("AttachmentTargetCompany")
  companyWarehouses     CompanyWarehouse[]     @relation("HolderCompanyWarehouses")
  operationalKits       OperationalKit[]       @relation("HolderOpKits")
  ymachGaps             YmachGap[]             @relation("HolderYmachGaps")
  verificationRequests  VerificationRequest[]  @relation("HolderVerifications")

  @@index([battalionId])
  @@index([kind])
  @@index([warehouseType])
}

// קשר מחסן↔פלוגה + נציג הפלוגה מול אותו מחסן (ניתן להעתקה ממחסן אחר)
model WarehouseCompany {
  id          String   @id @default(cuid())
  warehouseId String
  warehouse   Holder   @relation("WarehouseSide", fields: [warehouseId], references: [id], onDelete: Cascade)
  companyId   String
  company     Holder   @relation("CompanySide", fields: [companyId], references: [id], onDelete: Cascade)
  repUserId   String?
  repUser     AppUser? @relation("RepUser", fields: [repUserId], references: [id])

  @@unique([warehouseId, companyId])
}

// מידוף: מיקום פיזי במחסן (מחסן/עמודה/שורה)
model StorageLocation {
  id       String  @id @default(cuid())
  holderId String
  holder   Holder  @relation(fields: [holderId], references: [id], onDelete: Cascade)
  column   String // עמודה
  row      String // שורה
  label    String? // תיאור חופשי (אופציונלי)

  stockBalances StockBalance[]
  serialUnits   SerialUnit[]
  homeForItems  ItemType[]     @relation("ItemHomeLocation")
  // מיקומי פריטים פר-holder (מאפשר אותו פריט במיקומים שונים בכל מחסן/פלוגה)
  itemLocations ItemHolderLocation[]

  @@unique([holderId, column, row])
  @@index([holderId])
}

/**
 * 📍 מיקום ציוד בשטח (כשהגדוד מופעל).
 * נמצא ברמת holder (פלוגה/מחסן). מיועד להחליף את ה-physicalLocation החופשי.
 * דוגמאות: "אוהל מח״ט", "מחסן שדה", "ערמה צפונית". רכבים מתווספים אוטומטית.
 */
model EquipmentLocation {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id])
  holderId    String // פלוגה או מחסן
  holder      Holder   @relation(fields: [holderId], references: [id], onDelete: Cascade)
  name        String // "אוהל מ"כ", "ערמת ציוד", "רכב צ-12345"
  // אם המיקום הוא רכב — קישור ליחידה הסריאלית של הרכב (להציג עם מספר רכב)
  vehicleSerialUnitId String?
  vehicleSerialUnit   SerialUnit? @relation("EquipmentLocationVehicle", fields: [vehicleSerialUnitId], references: [id], onDelete: SetNull)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serialUnits SerialUnit[] @relation("SerialUnitEquipmentLocation")
  stockBalances StockBalance[] @relation("EquipmentLocationStock")
  soldierItemLocations SoldierItemLocation[] @relation("EquipmentLocationSoldierItems")
  operationalKits OperationalKit[] @relation("OpKitEquipmentLocation")

  @@unique([holderId, name])
  @@index([battalionId])
  @@index([holderId])
}

/**
 * מיקום פריט במידוף של holder ספציפי.
 * מאפשר אותו פריט (לדוגמה: סק"ש) להיות מאוחסן במיקום שונה בכל מחסן/פלוגה.
 * מחליף את ItemType.homeLocationId שהיה גלובלי.
 */
model ItemHolderLocation {
  id         String   @id @default(cuid())
  itemTypeId String
  itemType   ItemType @relation(fields: [itemTypeId], references: [id], onDelete: Cascade)
  holderId   String
  holder     Holder   @relation(fields: [holderId], references: [id], onDelete: Cascade)
  locationId String
  location   StorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([itemTypeId, holderId])
  @@index([itemTypeId])
  @@index([holderId])
  @@index([locationId])
}

enum SoldierStatus {
  REGISTERED   // 📝 רשום — נוצר במערכת
  ENLISTED     // ✅ מגויס — יכול לקבל ציוד
  DISCHARGED   // 🏠 משוחרר
  INACTIVE     // ⛔ לא פעיל
}

enum AttachmentRequestStatus {
  REQUESTED  // בקשה לסיפוח — מפ"מ הגיש
  SUBMITTED  // הוגשה בקשה — שלישות מטפלת
  REMINDED   // הוגשה תזכורת
  APPROVED   // אושר — חייל הוקם
  REJECTED   // לא אושר
}

model AttachmentRequest {
  id            String                  @id @default(cuid())
  battalionId   String
  battalion     Battalion               @relation(fields: [battalionId], references: [id], onDelete: Cascade)

  // פרטי חייל (החייל נוצר רק באישור)
  soldierName       String
  personalNumber    String?
  phone             String?
  sourceUnit        String?             // יחידת מקור / יחידה נוכחית
  targetCompanyId   String?
  targetCompany     Holder?             @relation("AttachmentTargetCompany", fields: [targetCompanyId], references: [id])

  // 🆕 שדות התאמה לקובץ המאסטר
  role          String?                 // תפקיד
  certifications String?                // הסמכות / היתרים
  interviewer   String?                 // מי ביצע ראיון
  frameName     String?                 // מסגרת בגדוד (טקסט חופשי)
  rawStatus     String?                 // סטטוס סיפוח כפי שנרשם (טקסט חופשי עם תאריכים)
  shmapNote     String?                 // האם בשמ"פ?

  fromDate      DateTime?               @db.Date
  toDate        DateTime?               @db.Date
  notes         String?

  status        AttachmentRequestStatus  @default(REQUESTED)

  // חייל שנוצר (רק אחרי אישור)
  soldierId     String?
  soldier       Soldier?                @relation(fields: [soldierId], references: [id], onDelete: SetNull)

  requestedById String
  requestedBy   AppUser                 @relation("AttachmentRequestedBy", fields: [requestedById], references: [id])
  requestedAt   DateTime                @default(now())

  // לוג שינויי סטטוס
  statusLog     AttachmentStatusLog[]

  @@index([battalionId])
  @@index([soldierId])
  @@index([status])
}

model AttachmentStatusLog {
  id          String                  @id @default(cuid())
  requestId   String
  request     AttachmentRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  status      AttachmentRequestStatus
  note        String?
  changedById String
  changedBy   AppUser                 @relation("AttachmentStatusChanged", fields: [changedById], references: [id])
  changedAt   DateTime                @default(now())
  @@index([requestId])
}

// ===================== חיילים =====================

model Soldier {
  id             String    @id @default(cuid())
  battalionId    String
  battalion      Battalion @relation(fields: [battalionId], references: [id])
  fullName       String  // השדה הזה משמש לתאימות לאחור — אם יש first/last יוצרים מהם
  firstName      String?
  lastName       String?
  personalNumber String? // אופציונלי — אפשר ליצור חייל בלעדיו ולעדכן בהמשך
  phone          String?
  platoon        String? // מחלקה בתוך הפלוגה (טקסט חופשי — לתאימות לאחור)
  squadId        String?
  squad          Squad?    @relation(fields: [squadId], references: [id])
  companyRoleId  String?
  companyRole    CompanyRole? @relation(fields: [companyRoleId], references: [id])
  companyId      String?
  company        Holder?   @relation(fields: [companyId], references: [id])
  dutyRound      Int?      // סבב תעסוקה — לשיבוץ החלפות סבב ברמת פלוגה
  dietType       String?   // מזון/כשרות: ציליאק | טבעוני | צמחוני | כשרות בד"ץ | ללא (עדכון עצמי בבוט)
  isAttendanceReporter Boolean @default(false) // נאמן כ"א — מדווח נוכחות (פלוגה, או המחלקה שלו אם משויך)
  fuelCards      VehicleFuelCard[]
  // שיוך משני — מחסן שהחייל גם משתייך אליו (למשל חייל ארמון שגם בפלוגה א')
  secondaryHolderId String?
  secondaryHolder   Holder? @relation("SoldierSecondary", fields: [secondaryHolderId], references: [id])
  status         SoldierStatus @default(REGISTERED)
  attached       Boolean       @default(false)
  enlistedAt     DateTime?
  enlistedById   String?
  dischargedAt   DateTime?
  // 🔫 תהליך קבלת נשק: 3 דגלים שצריכים להיות מסומנים. מתאפסים בהחזרת הנשק האחרון.
  // דגל 1: מג"ד/סמג"ד אישרו את החייל לחימוש
  weaponsApprovedAt   DateTime?
  weaponsApprovedById String?
  weaponsApprovalSignature String? // חתימה דיגיטלית של המאשר (מג"ד/סמג"ד/מפ"מ)
  // דגל 2: חייל העלה צילום מסך של מבחן נוהל הארמון
  armoryTestProofImage String? // data URL של הצילום
  armoryTestProofAt    DateTime?
  // אימות OCR של הצילום — true=מ"א תואם, false=לא זוהתה התאמה (דרוש אימות ידני), null=טרם נבדק
  armoryTestVerified   Boolean?
  armoryTestOcrText    String?  // הטקסט שחולץ מהתמונה (לתיעוד/דיבוג)
  // דגל 3: חתימה דיגיטלית על נוהל שמירת נשק (נחתם בארמון בזמן קבלת הנשק הראשון)
  weaponsAgreementSignedAt   DateTime?
  weaponsAgreementSignature  String? // data URL של החתימה
  // גיוס
  telegramChatId String? // Telegram chat ID לשליחת הודעות מבוט
  drivingRefresherDate DateTime? @db.Date // ריענון נהיגה כללי
  drivingProcedureSignedAt DateTime? // חתימה על נוהל נהיגה (דרך קצין רכב / בוט)
  // תיק נהג — פרטי רישיון אזרחי + צילום (קובץ 4)
  civilianLicenseNumber String? // מספר רישיון נהיגה אזרחי
  civilianLicenseGrade  String? // דרגות רישיון (למשל: B, C1, C, E)
  civilianLicenseExpiry DateTime? @db.Date // תוקף רישיון אזרחי — נכנס לבדיקת שיבוץ נהג
  licensePhotoData      String? // (legacy) צילום רישיון בודד
  civilianLicenseFrontData String? // צילום רישיון אזרחי — צד קדמי
  civilianLicenseBackData  String? // צילום רישיון אזרחי — צד אחורי
  militaryLicenseFrontData String? // צילום רישיון צבאי — קדמי בלבד
  driverFileApprovedAt  DateTime? // אישור תיק נהג ע"י קצין רכב
  driverFileApprovedById String? // מי אישר את התיק
  driverForms           DriverForm[] @relation("SoldierDriverForms")
  callupClosedAt DateTime? // תאריך סגירת גיוס
  createdAt      DateTime  @default(now())

  signedSerialUnits  SerialUnit[]  @relation("SerialUnitSignedSoldier")
  signedKitInstances KitInstance[] @relation("KitInstanceSignedSoldier")
  transfersTo        Transfer[]    @relation("TransferToSoldier")
  signatures         Signature[]
  itemLocations      SoldierItemLocation[] @relation("SoldierItemLocations")
  dispatchAssignments VehicleAssignmentSoldier[] @relation("SoldierDispatch")
  commandedMissions   Mission[]                  @relation("MissionCommander")
  dispatchTemplates   DispatchTemplateSoldier[] @relation("SoldierDispatchTemplate")
  drivingLicenses     SoldierDrivingLicense[]   @relation("SoldierDrivingLicenses")
  certifications      SoldierCertification[]    @relation("SoldierCertifications")
  courseEnrollments   CourseEnrollment[]        @relation("SoldierCourseEnrollments")
  courseRequests      CourseRequest[]           @relation("SoldierCourseRequests")
  warehouseIndexes    WarehouseSoldierIndex[]   @relation("SoldierWarehouseIndex")
  attendancePlans    AttendancePlan[]
  attendanceRecords  AttendanceRecord[]
  callupPeriods      CallupPeriod[]
  scheduleDaySoldiers ScheduleDaySoldier[] @relation("SoldierScheduleDay")
  attachmentRequests  AttachmentRequest[]
  operationalKits     OperationalKit[] @relation("SoldierOpKits")
  ymachGaps           YmachGap[]       @relation("SoldierYmachGaps")
  verificationRequests VerificationRequest[] @relation("SoldierVerifications")
  countLines           CountLine[]            @relation("CountLineSoldier")
  countTasks           CountTask[]            @relation("CountTaskSoldier")
  // מקושר למשתמש מערכת (קצין/רס"פ)
  appUser            AppUser?      @relation("SoldierAsUser")

  @@unique([battalionId, personalNumber])
  @@index([companyId])
  @@index([squadId])
}

/**
 * כמות בסיס פר (פלוגה, פריט) - הכמות שנשארת אצל הפלוגה גם אחרי תעסוקה.
 * רק מפמ עורך. ברירת מחדל = 0 (כל הציוד מושאל וצריך לחזור).
 * משמש כדי לאכוף בזיכוי: לא ניתן לזכות מתחת ל-baseline.
 * אגרגטיבי - לא תלוי סטטוס (תקין/תקול/אובד).
 */
/**
 * שבצ"ק - שיבוץ חיילים לרכב למשימה.
 * נראה לכולם, ניתן לעריכה ע"י כולם, מינימום שדות (ביטחון מידע).
 */
// 🆕 משימה = שיירה של כמה רכבים (VehicleAssignment) תחת תאריך/שעה/פלוגה אחת
model Mission {
  id            String   @id @default(cuid())
  battalionId   String
  battalion     Battalion @relation("BattalionMissions", fields: [battalionId], references: [id], onDelete: Cascade)
  companyId     String?
  company       Holder?  @relation("CompanyMissions", fields: [companyId], references: [id], onDelete: SetNull)
  title         String?
  // מפקד משימה — חייל מהרוסטר (יכול לקבל בבוט + לסגור משימה) או שם חופשי
  commanderSoldierId String?
  commanderSoldier   Soldier? @relation("MissionCommander", fields: [commanderSoldierId], references: [id], onDelete: SetNull)
  commanderName String?
  missionDate   DateTime
  departureTime String
  notes         String?
  createdById   String
  createdBy     AppUser  @relation("MissionCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?
  completedById String?
  // 🆕 התחלת משימה — נחסמת עד שכל הנהגים דיווחו שהקימו הרשאת/לינק נסיעה
  startedAt     DateTime?
  startedById   String?
  vehicles      VehicleAssignment[]

  @@index([battalionId, missionDate])
}

model VehicleAssignment {
  id                  String   @id @default(cuid())
  battalionId         String
  battalion           Battalion @relation("BattalionDispatch", fields: [battalionId], references: [id], onDelete: Cascade)
  companyId           String?
  company             Holder?  @relation("CompanyDispatch", fields: [companyId], references: [id], onDelete: SetNull)
  // 🆕 שיוך למשימה רב-רכבית (null = שיבוץ רכב-יחיד ישן, ממשיך לעבוד)
  missionId           String?
  mission             Mission? @relation(fields: [missionId], references: [id], onDelete: Cascade)
  // רכב מהמערכת (null עבור רכב חוץ)
  vehicleSerialUnitId String?
  vehicleSerialUnit   SerialUnit? @relation("VehicleAssignmentVehicle", fields: [vehicleSerialUnitId], references: [id], onDelete: Cascade)
  // 🆕 רכב חוץ — מגיע מיחידה אחרת, לא במערכת
  isExternal              Boolean @default(false)
  externalVehicleNumber   String?
  externalVehicleTypeName String?
  convoyOrder             Int?    // 🆕 מיקום ברכב בשיירה (סדר יציאה)
  missionDate         DateTime // תאריך משימה (ביום הראשון של היום - שעה 00:00)
  departureTime       String   // שעת יציאה כ-string HH:mm (פשוט יותר משילוב בתאריך)
  createdById         String
  createdBy           AppUser  @relation("DispatchCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  updatedById         String?
  // 🆕 סימון השלמת משימה - מתי הסתיימה. NULL = פעילה
  completedAt         DateTime?
  completedById       String?

  soldiers            VehicleAssignmentSoldier[]

  @@index([battalionId, missionDate])
  @@index([battalionId, completedAt])
  @@index([vehicleSerialUnitId])
  @@index([missionId])
}

model VehicleAssignmentSoldier {
  id           String   @id @default(cuid())
  assignmentId String
  assignment   VehicleAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  soldierId    String?
  soldier      Soldier? @relation("SoldierDispatch", fields: [soldierId], references: [id], onDelete: Cascade)
  // 🆕 נהג הרכב — מקבל הודעת בוט "שובצת למשימה"
  isDriver     Boolean  @default(false)
  // 🆕 חייל חוץ — לא במערכת, שם + מ.א ידניים
  externalName           String?
  externalPersonalNumber String?
  // 🆕 תפקיד בשבצ"ק (נהג / מפקד רכב / לוחם) — כמו בתבנית שבצ"ק קבוע
  dispatchRoleId         String?
  dispatchRole           DispatchRole? @relation("VehicleAssignmentSoldierRole", fields: [dispatchRoleId], references: [id], onDelete: SetNull)
  // 🆕 חיווי נהג שהקים הרשאת/לינק נסיעה. מדווח ע"י הנהג בבוט או ע"י קצין הרכב.
  tripConfirmedAt        DateTime?
  tripConfirmedVia       String?  // "נהג (בוט)" / שם קצין הרכב / "ידני"
  createdAt    DateTime @default(now())

  @@unique([assignmentId, soldierId])
  @@index([soldierId])
}

model CompanyItemBaseline {
  id                 String    @id @default(cuid())
  battalionId        String
  battalion          Battalion @relation("BattalionBaselines", fields: [battalionId], references: [id], onDelete: Cascade)
  companyId          String
  company            Holder    @relation("HolderBaselines", fields: [companyId], references: [id], onDelete: Cascade)
  itemTypeId         String
  itemType           ItemType  @relation("ItemTypeBaselines", fields: [itemTypeId], references: [id], onDelete: Cascade)
  permanentQuantity  Int       @default(0)
  updatedAt          DateTime  @updatedAt
  updatedById        String?

  @@unique([companyId, itemTypeId])
  @@index([battalionId])
  @@index([companyId])
  @@index([itemTypeId])
}

// הקצאת ציוד ארמון לפלוגה (כמה מגיע מכל פריט). מנוהל ע"י מגד/סמגד/מפמ.
model CompanyAllocation {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation("BattalionAllocations", fields: [battalionId], references: [id], onDelete: Cascade)
  companyId   String
  company     Holder    @relation("HolderAllocations", fields: [companyId], references: [id], onDelete: Cascade)
  itemTypeId  String
  itemType    ItemType  @relation("ItemTypeAllocations", fields: [itemTypeId], references: [id], onDelete: Cascade)
  quantity       Int       @default(0)
  blockOnExceed  Boolean   @default(true) // true = חסום החתמה בחריגה, false = התראה בלבד
  updatedAt      DateTime  @updatedAt
  updatedById    String?

  @@unique([companyId, itemTypeId])
  @@index([battalionId])
  @@index([companyId])
  @@index([itemTypeId])
}

// ===================== מילונים (לפי גדוד) =====================

model Category {
  id            String        @id @default(cuid())
  battalionId   String
  battalion     Battalion     @relation(fields: [battalionId], references: [id])
  warehouseType WarehouseType // לכל סוג מחסן קטגוריות משלו
  name          String
  active        Boolean       @default(true)
  sortOrder     Int           @default(0)
  maxPerSoldier Int?          // מקס' יחידות מהקטגוריה (סה"כ מכל הסוגים) לחייל (null = ללא הגבלה)
  itemTypes     ItemType[]

  @@unique([battalionId, name])
  @@index([battalionId, warehouseType])
}

model ItemStatus {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id])
  name        String
  isDefault   Boolean   @default(false)
  isLoss      Boolean   @default(false)
  isWear      Boolean   @default(false)
  isConsumed  Boolean   @default(false)
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)

  serialUnits   SerialUnit[]
  stockBalances StockBalance[]
  transferLines TransferLine[]
  soldierItemLocations SoldierItemLocation[]

  @@unique([battalionId, name])
}

model CountFrequency {
  id           String            @id @default(cuid())
  battalionId  String
  battalion    Battalion         @relation(fields: [battalionId], references: [id])
  name         String
  intervalDays Int               @default(7)
  active       Boolean           @default(true)
  countDefs    CountDefinition[]

  @@unique([battalionId, name])
}

// ===================== קטלוג פריטים =====================

// שייכות הפריט: צבאי / תרומה פלוגתי / תרומה גדודי
enum ItemAssociation {
  MILITARY
  DONATION_COMPANY
  DONATION_BATTALION
}

// מצב החתמה: מי חותם — מפקד הפלוגה (אופייני לציוד כללי כקסדות/אפודים), או חייל ישירות (נשק מהארמון)
enum SignMode {
  COMPANY
  SOLDIER
}

model ItemType {
  id             String           @id @default(cuid())
  battalionId    String
  battalion      Battalion        @relation(fields: [battalionId], references: [id])
  sku            String? // מק"ט — אופציונלי
  name           String
  categoryId     String?
  category       Category?        @relation(fields: [categoryId], references: [id])
  trackingMethod TrackingMethod
  unit           String           @default("יח'")
  association    ItemAssociation  @default(MILITARY) // צבאי / תרומה פלוגתי / תרומה גדודי
  signMode       SignMode         @default(COMPANY) // החתמת פלוגה (ברירת מחדל) או חייל ישיר (נשק)
  isSensitive    Boolean          @default(false)
  trackLocation  Boolean          @default(false)
  // האם החייל רשאי לעדכן בעצמו (בבוט) את מיקום הפריט החתום עליו
  allowLocationUpdate Boolean      @default(false)
  // האם הפריט יש לו תאריך תפוגה — אם כן, חובה להזין תאריך תפוגה בקבלה למלאי
  trackExpiry    Boolean          @default(false)
  expiryAlertDays Int?            // התראה X ימים לפני פקיעת תוקף (רק לפריטי trackExpiry)
  // תרומה / ציוד לא-צבאי (נגזר מ-association לתאימות)
  isDonated      Boolean          @default(false)
  signable       Boolean          @default(true) // האם ניתן להחתים חיילים על הפריט
  maxPerSoldier  Int?             // מקס' יחידות מסוג זה שחייל יכול להיות חתום עליהן (null = ללא הגבלה)
  ownerHolderId  String? // הבעלים של מלאי התרומה (פלוגה); null = רמת גדוד
  ownerHolder    Holder?          @relation("ItemOwnerHolder", fields: [ownerHolderId], references: [id])
  imageData      String?
  // מיקום במחסן הסופי (כאשר מסתיימת הפעילות)
  homeLocationId String?
  homeLocation   StorageLocation? @relation("ItemHomeLocation", fields: [homeLocationId], references: [id])
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())

  stockBalances StockBalance[]
  serialUnits   SerialUnit[]
  transferLines TransferLine[]
  countLines    CountLine[]
  discrepancies Discrepancy[]
  kitComponents KitComponent[] @relation("KitParent")
  usedInKits    KitComponent[] @relation("KitChild")
  kitInstances  KitInstance[]
  soldierItemLocations SoldierItemLocation[]
  companyBaselines   CompanyItemBaseline[] @relation("ItemTypeBaselines")
  companyAllocations CompanyAllocation[]  @relation("ItemTypeAllocations")
  // מיקומים פר-holder (מאפשר אותו פריט במיקומים שונים בכל מחסן/פלוגה)
  holderLocations ItemHolderLocation[]
  inSignableKits SignableKitLine[] @relation("KitLineItem")
  requiredLicenses VehicleTypeLicense[] @relation("ItemTypeRequiredLicense")
  dispatchTemplates DispatchTemplate[] @relation("DispatchTemplateVehicleType")
  companyShelfItems CompanyShelfItem[] @relation("ItemTypeOnShelf")
  operationalKitItems OperationalKitItem[] @relation("ItemTypeInOpKit")
  ymachGaps         YmachGap[]           @relation("YmachGapItemType")

  @@unique([battalionId, sku])
  @@index([categoryId])
  @@index([trackingMethod])
}

model KitComponent {
  id              String   @id @default(cuid())
  kitItemTypeId   String
  kitItemType     ItemType @relation("KitParent", fields: [kitItemTypeId], references: [id], onDelete: Cascade)
  componentTypeId String
  componentType   ItemType @relation("KitChild", fields: [componentTypeId], references: [id])
  quantity        Int      @default(1)

  @@unique([kitItemTypeId, componentTypeId])
}

// ===================== מלאי =====================

model StockBalance {
  id          String           @id @default(cuid())
  battalionId String
  battalion   Battalion        @relation(fields: [battalionId], references: [id])
  itemTypeId  String
  itemType    ItemType         @relation(fields: [itemTypeId], references: [id])
  holderId    String
  holder      Holder           @relation(fields: [holderId], references: [id])
  statusId    String
  status      ItemStatus       @relation(fields: [statusId], references: [id])
  locationId  String?
  location    StorageLocation? @relation(fields: [locationId], references: [id])
  // 🆕 מיקום פיזי בשטח (אוהל / רכב / ערמה) — חלק מהמפתח: שורה לכל (item, holder, status, location).
  // מאפשר אותו פריט להיות פיזית במספר מיקומים בו זמנית (למשל אלונקה ברכבים שונים + מחסן).
  // NULL = "ללא מיקום מוגדר" - שורה אחת בלבד כזאת לכל (item, holder, status) באכיפת DB (NULLS NOT DISTINCT).
  equipmentLocationId String?
  equipmentLocation   EquipmentLocation? @relation("EquipmentLocationStock", fields: [equipmentLocationId], references: [id], onDelete: SetNull)
  quantity    Int              @default(0)
  updatedAt   DateTime         @updatedAt

  @@unique([itemTypeId, holderId, statusId, equipmentLocationId])
  @@index([battalionId])
  @@index([holderId])
  @@index([equipmentLocationId])
}

/**
 * מיקום של ציוד כמותי שחתום על חייל.
 * כשחייל חתום על 3 פטישים, המערכת תאפשר לציין: 1 ברכב צ-12345, 2 באוהל מ"כ.
 * הסכום של quantity ב-(soldier, item, status) צריך להיות שווה לכמות החתומה (SIGNOUT minus CHECKIN).
 * השמירה נעשית ידנית מהמסך - לא מתעדכנת אוטומטית מהחתימה.
 */
model SoldierItemLocation {
  id                  String   @id @default(cuid())
  battalionId         String
  battalion           Battalion @relation(fields: [battalionId], references: [id])
  soldierId           String
  soldier             Soldier  @relation("SoldierItemLocations", fields: [soldierId], references: [id], onDelete: Cascade)
  itemTypeId          String
  itemType            ItemType @relation(fields: [itemTypeId], references: [id], onDelete: Cascade)
  statusId            String
  status              ItemStatus @relation(fields: [statusId], references: [id])
  equipmentLocationId String
  equipmentLocation   EquipmentLocation @relation("EquipmentLocationSoldierItems", fields: [equipmentLocationId], references: [id], onDelete: Cascade)
  quantity            Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([soldierId, itemTypeId, statusId, equipmentLocationId])
  @@index([battalionId])
  @@index([soldierId])
  @@index([equipmentLocationId])
}

model SerialUnit {
  id           String     @id @default(cuid())
  battalionId  String
  battalion    Battalion  @relation(fields: [battalionId], references: [id])
  itemTypeId   String
  itemType     ItemType   @relation(fields: [itemTypeId], references: [id])
  serialNumber String
  lotQuantity  Int?
  statusId     String
  status       ItemStatus @relation(fields: [statusId], references: [id])

  currentHolderId  String?
  currentHolder    Holder?          @relation("SerialUnitHolder", fields: [currentHolderId], references: [id])
  signedSoldierId  String?
  signedSoldier    Soldier?         @relation("SerialUnitSignedSoldier", fields: [signedSoldierId], references: [id])
  externalHolderName String? // 🆕 כשהיחידה חתומה על גורם חוץ — שם הגורם (currentHolderId=null)
  physicalLocation String? // ⚠️ Deprecated — שדה טקסט חופשי ישן. השתמש ב-equipmentLocationId
  // 🆕 מיקום ציוד מהרשימה המוגדרת (במקום טקסט חופשי)
  equipmentLocationId String?
  equipmentLocation   EquipmentLocation? @relation("SerialUnitEquipmentLocation", fields: [equipmentLocationId], references: [id])
  // אם הפריט נמצא ברכב — שיוך לרכב (SerialUnit מטיפוס רכב)
  vehicleId        String?
  vehicle          SerialUnit?      @relation("SerialUnitVehicle", fields: [vehicleId], references: [id])
  storedItems      SerialUnit[]     @relation("SerialUnitVehicle")
  // אם זו יחידת רכב — מיקומי ציוד שמצביעים אליה
  asEquipmentLocations EquipmentLocation[] @relation("EquipmentLocationVehicle")
  dispatchAssignments  VehicleAssignment[] @relation("VehicleAssignmentVehicle")
  dispatchTemplates    DispatchTemplate[]  @relation("DispatchTemplateVehicle")
  locationId       String?
  location         StorageLocation? @relation(fields: [locationId], references: [id])

  kitInstanceId String?
  kitInstance   KitInstance? @relation(fields: [kitInstanceId], references: [id])

  // ימ"ח — אפסון: פריט נשאר חתום על החייל אבל מאוחסן פיזית במדף
  storageStatus   String   @default("ACTIVE") // "ACTIVE" | "STORED"
  storedShelfId   String?
  storedShelf     CompanyShelf? @relation("StoredOnShelf", fields: [storedShelfId], references: [id], onDelete: SetNull)
  storedAt        DateTime?
  storedByUserId  String?

  // תאריך תפוגה — רלוונטי בעיקר ל-LOT (תרופות, אצוות) ולפריטים סריאליים בודדים שיש להם תפוגה
  expiryDate DateTime?

  dischargedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transferLines TransferLine[]
  countLines    CountLine[]
  ymachGaps     YmachGap[]    @relation("YmachGapSerialUnit")
  verificationItems VerificationItem[] @relation("SerialUnitVerifications")
  maintenance   VehicleMaintenance? @relation("VehicleMaintenanceUnit")
  faults        VehicleFault[]      @relation("VehicleFaultUnit")

  @@unique([itemTypeId, serialNumber])
  @@index([battalionId])
  @@index([currentHolderId])
  @@index([signedSoldierId])
  @@index([battalionId, expiryDate])
  @@index([storageStatus])
}

model KitInstance {
  id            String    @id @default(cuid())
  battalionId   String
  battalion     Battalion @relation(fields: [battalionId], references: [id])
  kitItemTypeId String
  kitItemType   ItemType  @relation(fields: [kitItemTypeId], references: [id])
  label         String

  currentHolderId String?
  currentHolder   Holder?  @relation("KitInstanceHolder", fields: [currentHolderId], references: [id])
  signedSoldierId String?
  signedSoldier   Soldier? @relation("KitInstanceSignedSoldier", fields: [signedSoldierId], references: [id])

  createdAt DateTime @default(now())

  serialUnits SerialUnit[]
  qtyLines    KitQtyLine[]

  @@index([battalionId])
  @@index([currentHolderId])
}

model KitQtyLine {
  id            String      @id @default(cuid())
  kitInstanceId String
  kitInstance   KitInstance @relation(fields: [kitInstanceId], references: [id], onDelete: Cascade)
  itemTypeId    String
  quantity      Int         @default(1)
  present       Boolean     @default(true)
}

// ===================== העברות =====================

model Transfer {
  id          String         @id @default(cuid())
  battalionId String
  battalion   Battalion      @relation(fields: [battalionId], references: [id])
  type        TransferType
  status      TransferStatus @default(PENDING)
  // חתימה בדיעבד: הפריט כבר שויך לחייל וירד מהמלאי (status=COMPLETED), אך החייל טרם חתם דיגיטלית.
  signaturePending Boolean    @default(false)

  fromHolderId String?
  fromHolder   Holder?  @relation("TransferFrom", fields: [fromHolderId], references: [id])
  toHolderId   String?
  toHolder     Holder?  @relation("TransferTo", fields: [toHolderId], references: [id])
  toSoldierId  String?
  toSoldier    Soldier? @relation("TransferToSoldier", fields: [toSoldierId], references: [id])
  // נמען-משתמש (החתמת פלוגה: מפ/רס"פ חותם בשם הפלוגה)
  toUserId     String?
  toUser       AppUser? @relation("TransferToUser", fields: [toUserId], references: [id])

  reason String?
  notes  String?
  // עבור העברות מול גורם חיצוני (חטיבה / יחידה אחרת). externalUnit = שייכות.
  externalUnit    String?
  externalContact String?
  // מספר אישי של מקבל המסירה (אם הגדוד דורש זאת)
  recipientPersonalId String?
  // 🆕 החתמת/זיכוי חוץ — פרטי הגורם החיצוני + חתימתו על התעודה
  externalName      String? // שם מלא של מקבל/מוסר החוץ
  externalPhone     String? // נייד
  externalSignature String? // data URL של חתימת הגורם החיצוני

  createdById  String
  createdBy    AppUser  @relation("TransferCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   AppUser? @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  pdfPath    String?
  createdAt  DateTime  @default(now())
  approvedAt DateTime?

  lines      TransferLine[]
  signatures Signature[]

  @@index([battalionId])
  @@index([status])
}

model TransferLine {
  id         String   @id @default(cuid())
  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemTypeId String
  itemType   ItemType @relation(fields: [itemTypeId], references: [id])
  quantity   Int      @default(1)

  serialUnitId  String?
  serialUnit    SerialUnit? @relation(fields: [serialUnitId], references: [id])
  kitInstanceId String?
  statusId      String?
  status        ItemStatus? @relation(fields: [statusId], references: [id])

  @@index([transferId])
}

// ===================== החתמות =====================

model Signature {
  id            String          @id @default(cuid())
  battalionId   String
  battalion     Battalion       @relation(fields: [battalionId], references: [id])
  // החתימה היא של חייל (soldierId) או של משתמש פלוגתי (signerUserId — לדוגמה מפ/רס"פ)
  soldierId     String?
  soldier       Soldier?        @relation(fields: [soldierId], references: [id])
  signerUserId  String?
  signerUser    AppUser?        @relation("SignerUser", fields: [signerUserId], references: [id])
  transferId    String?
  transfer      Transfer?       @relation(fields: [transferId], references: [id])
  method        SignatureMethod
  status        SignatureStatus @default(PENDING)
  token         String          @unique
  tokenExpires  DateTime?
  signatureData String?
  // מספר אישי של החותם (אם הגדוד דורש זאת)
  signerPersonalId String?
  signedAt      DateTime?
  createdAt     DateTime        @default(now())

  @@index([battalionId])
  @@index([status])
}

// ===================== ספירות ופערים =====================

/**
 * תכנית ספירה — המפ"מ מגדיר מה סופרים, איפה, מתי, וכל כמה זמן.
 * מוליד CountTask לכל holder בהיקף, בכל זמן מתוזמן.
 */
model CountPlan {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id])
  name        String
  description String?

  // היקף — אם ריק, חל על כל המחסנים+פלוגות הפעילים
  scopeHolderIds   String[] @default([])
  scopeCategoryIds String[] @default([])
  scopeItemTypeIds String[] @default([])
  trackingMethods  String[] @default([]) // ["SERIAL","QUANTITY","LOT","KIT"]

  // תזמון
  frequencyDays  Int      @default(1)   // 0 = חד-פעמי, 1 = יומי, 7 = שבועי
  scheduledTimes String[] @default([])  // ["08:00","20:00"] — מספר פעמים ביום
  daysOfWeek     Int[]    @default([])  // ריק = כל הימים; אחרת 0..6
  graceMinutes   Int      @default(60)  // דקות עד OVERDUE
  // טווח תאריכים — אופציונלי. אם startDate מוגדר, התכנית פעילה רק החל ממנו. endDate = עד מתי.
  startDate      DateTime?
  endDate        DateTime?

  active      Boolean  @default(true)
  isBlind     Boolean  @default(false)
  signOnComplete   Boolean @default(false) // "ספירת החתמה" — הדיווח מחתים את החייל/פלוגה על הציוד
  correctByReporter Boolean @default(false) // האם המדווח בקצה יכול לתקן, או רק מקים הספירה
  countScope  CountScope @default(WAREHOUSE_STOCK)
  createdById String
  createdBy   AppUser  @relation("CountPlanCreatedBy", fields: [createdById], references: [id])
  // אחראי ספירה — רואה את התכנית, סטטוס כל המשימות, ומייצא דוח. ברירת מחדל = createdBy.
  responsibleUserId String?
  responsibleUser   AppUser? @relation("CountPlanResponsible", fields: [responsibleUserId], references: [id])
  createdAt   DateTime @default(now())

  tasks CountTask[]

  @@index([battalionId])
}

/**
 * משימת ספירה — נוצרת אוטומטית מתכנית. אחת לכל holder בהיקף + לכל זמן מתוזמן.
 * האחראי מדווח ומסיים, או מעביר ב-WhatsApp לאחר (shareToken).
 */
model CountTask {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id])
  planId      String?
  plan        CountPlan? @relation(fields: [planId], references: [id], onDelete: Cascade)

  holderId String
  holder   Holder @relation(fields: [holderId], references: [id])
  soldierId String?
  soldier   Soldier? @relation("CountTaskSoldier", fields: [soldierId], references: [id])
  // אחראי דיווח. ברירת מחדל = משתמש "הראשי" של ה-holder. ניתן להחליף.
  assignedUserId String?
  assignedUser   AppUser? @relation("CountTaskAssigned", fields: [assignedUserId], references: [id])

  scheduledAt DateTime
  dueAt       DateTime                              // scheduledAt + graceMinutes
  startedAt   DateTime?
  completedAt DateTime?
  status      CountTaskStatus @default(PENDING)

  // לפתיחה ללא login (שיתוף ב-WhatsApp)
  shareToken String @unique @default(nanoid(24))
  // קישור לסשן הספירה האמיתי
  sessionId  String?  @unique
  session    CountSession? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  @@index([battalionId, status])
  @@index([assignedUserId, status])
}

model CountDefinition {
  id            String          @id @default(cuid())
  battalionId   String
  battalion     Battalion       @relation(fields: [battalionId], references: [id])
  name          String
  type          CountType
  frequencyId   String?
  frequency     CountFrequency? @relation(fields: [frequencyId], references: [id])
  scopeHolderId String?
  scopeHolder   Holder?         @relation("CountDefHolder", fields: [scopeHolderId], references: [id])
  categoryIds   String[]
  daysOfWeek    Int[]
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())

  sessions CountSession[]
}

model CountSession {
  id           String             @id @default(cuid())
  battalionId  String
  battalion    Battalion          @relation(fields: [battalionId], references: [id])
  definitionId String?
  definition   CountDefinition?   @relation(fields: [definitionId], references: [id])
  type         CountType
  status       CountSessionStatus @default(DRAFT)
  frozen       Boolean            @default(false)
  isBlind      Boolean            @default(false)
  signOnComplete    Boolean       @default(false)
  correctByReporter Boolean       @default(false)
  startedById  String
  startedBy    AppUser            @relation("CountStartedBy", fields: [startedById], references: [id])
  startedAt    DateTime           @default(now())
  completedAt  DateTime?

  lines         CountLine[]
  discrepancies Discrepancy[]
  task          CountTask?
  verificationRequests VerificationRequest[] @relation("SessionVerifications")

  @@index([battalionId])
}

model CountLine {
  id           String       @id @default(cuid())
  sessionId    String
  session      CountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  itemTypeId   String
  itemType     ItemType     @relation(fields: [itemTypeId], references: [id])
  holderId     String?
  holder       Holder?      @relation(fields: [holderId], references: [id])
  serialUnitId String?
  serialUnit   SerialUnit?  @relation(fields: [serialUnitId], references: [id])
  soldierId    String?
  soldier      Soldier?     @relation("CountLineSoldier", fields: [soldierId], references: [id])
  signerUserId String?
  expectedQty  Int          @default(0)
  countedQty   Int?
  enteredSerial String?
  photoData    String?
  note         String?

  @@index([sessionId])
}

model Discrepancy {
  id           String            @id @default(cuid())
  battalionId  String
  battalion    Battalion         @relation(fields: [battalionId], references: [id])
  sessionId    String?
  session      CountSession?     @relation(fields: [sessionId], references: [id])
  itemTypeId   String
  itemType     ItemType          @relation(fields: [itemTypeId], references: [id])
  holderId     String?
  holder       Holder?           @relation(fields: [holderId], references: [id])
  expectedQty  Int
  countedQty   Int
  diff         Int
  kind         DiscrepancyKind
  status       DiscrepancyStatus @default(OPEN)
  resolution   String?
  resolvedById String?
  resolvedBy   AppUser?          @relation("DiscrepancyResolvedBy", fields: [resolvedById], references: [id])
  createdAt    DateTime          @default(now())
  resolvedAt   DateTime?

  @@index([battalionId])
  @@index([status])
}

// ===================== יומן פעולות =====================

model AuditLog {
  id          String     @id @default(cuid())
  battalionId String?
  battalion   Battalion? @relation(fields: [battalionId], references: [id])
  userId      String?
  user        AppUser?   @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  details     Json?
  // 🔐 Hash chain — מונע שינוי רטרואקטיבי של היומן
  prevHash    String? // ה-hash של הרישום הקודם
  hash        String? // hash של ערכי הרישום הנוכחי + prevHash
  createdAt   DateTime   @default(now())

  @@index([battalionId])
  @@index([entity, entityId])
}

// ===================== Rate Limiting =====================

model RateLimitHit {
  id        String   @id @default(cuid())
  scope     String   // לדוגמה: "login"
  key       String   // לרוב IP
  createdAt DateTime @default(now())

  @@index([scope, key, createdAt])
  @@index([createdAt]) // לניקוי תקופתי
}

// ===================== מחלקות (Squads) =====================

model Squad {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  companyId   String
  company     Holder   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  soldiers    Soldier[]
  assignedUsers UserSquad[]

  @@unique([companyId, name])
  @@index([battalionId])
  @@index([companyId])
}

// ===================== תפקידי פלוגה (Company Roles) =====================

model CompanyRole {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Holder?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  isCommander Boolean  @default(false)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  soldiers      Soldier[]
  dispatchRoles DispatchRole[] @relation("DispatchRoleCompanyRole")

  @@unique([companyId, name])
  @@index([battalionId])
  @@index([companyId])
}

// ===================== נוכחות (Attendance) =====================

model AttendanceStatus {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  name        String   // למשל: נוכח, חופשה, מחלה, ח.מ., וכו'
  color       String   @default("#10b981") // hex color
  icon        String?  // emoji
  isPresent   Boolean  @default(false) // האם נחשב "נוכח" לצורך חישוב אחוז
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  plans       AttendancePlan[]
  records     AttendanceRecord[]

  @@unique([battalionId, name])
  @@index([battalionId])
}

model AttendancePlan {
  id          String   @id @default(cuid())
  soldierId   String
  soldier     Soldier  @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  statusId    String
  status      AttendanceStatus @relation(fields: [statusId], references: [id])
  note        String?
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@unique([soldierId, date])
  @@index([soldierId])
  @@index([date])
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  soldierId   String
  soldier     Soldier  @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  statusId    String
  status      AttendanceStatus @relation(fields: [statusId], references: [id])
  note        String?
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@unique([soldierId, date])
  @@index([soldierId])
  @@index([date])
}

/**
 * נעילת נוכחות פר-פלוגה ליום — השלישות "נועלת" את יכולת העדכון של פלוגה.
 * כשקיימת נעילה, נציג פלוגה חסום מלערוך נוכחות ליום זה; שלישות/אדמין עדיין יכולים.
 */
model AttendanceLock {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation("BattalionAttendanceLocks", fields: [battalionId], references: [id], onDelete: Cascade)
  companyId   String   // holder מסוג COMPANY
  company     Holder   @relation("CompanyAttendanceLocks", fields: [companyId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  lockedById  String
  lockedAt    DateTime @default(now())

  @@unique([companyId, date])
  @@index([battalionId, date])
}

// ===================== שמ"פ (שירות מילואים פעיל) =====================

model CallupPeriod {
  id          String    @id @default(cuid())
  soldierId   String
  soldier     Soldier   @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  createdById String?
  closedById  String?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@index([soldierId])
  @@index([startDate])
}

// ===================== תיק נהג (Driver File) =====================
// 3 טפסים מובנים (מילוי דיגיטלי + הדפסה + חתימה) + צילום רישיון על החייל = 4 קבצים.
// סוגי טפסים: SAFETY_TRACKING (תיק נהג ומעקב בטיחות) · SAFETY_CHECKOUT (הכשרת בטיחות א-ז) · LICENSE_DECLARATION (הצהרת בעל רישיון)

model DriverFormValidity {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  formType    String    // SAFETY_TRACKING | SAFETY_CHECKOUT | LICENSE_DECLARATION
  validityDays Int      @default(365) // 0 = ללא תוקף (קבוע)

  @@unique([battalionId, formType])
  @@index([battalionId])
}

model DriverForm {
  id                   String    @id @default(cuid())
  battalionId          String
  battalion            Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  soldierId            String
  soldier              Soldier   @relation("SoldierDriverForms", fields: [soldierId], references: [id], onDelete: Cascade)
  formType             String    // SAFETY_TRACKING | SAFETY_CHECKOUT | LICENSE_DECLARATION
  data                 Json      // שדות הטופס המובנים
  signatureData        String?   // חתימה דיגיטלית (dataURL)
  signerName           String?   // שם החותם
  signerPersonalNumber String?   // מ.א החותם
  filledById           String?   // AppUser שמילא
  filledAt             DateTime  @default(now())
  validUntil           DateTime? // filledAt + תוקף פר-טופס (null = קבוע)

  @@unique([soldierId, formType])
  @@index([soldierId])
  @@index([battalionId])
}

// ===================== העברת משמרת / סבב (Shift Handover) =====================

model ShiftHandover {
  id            String    @id @default(cuid())
  battalionId   String
  battalion     Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  companyId     String    // Holder (פלוגה)
  company       Holder    @relation("HolderShiftHandovers", fields: [companyId], references: [id], onDelete: Cascade)
  fromRound     Int?      // סבב יוצא
  toRound       Int?      // סבב נכנס
  title         String?
  status        String    @default("OPEN") // OPEN | COMPLETED
  note          String?
  createdById   String
  completedById String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  items ShiftHandoverItem[]

  @@index([battalionId, companyId])
}

model ShiftHandoverItem {
  id          String        @id @default(cuid())
  handoverId  String
  handover    ShiftHandover @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  category    String        // EQUIPMENT | DISPATCH | COUNT | GAP | MANUAL
  label       String
  done        Boolean       @default(false)
  note        String?
  sortOrder   Int           @default(0)

  @@index([handoverId])
}

// ===================== תעסוקה (Employment) =====================

model Employment {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  name        String   // שם התעסוקה
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  totalDays   Int      // סה"כ ימי מילואים מאושרים
  mode        String   @default("daily") // "daily" = הקצאה יומית, "total" = סה"כ לתעסוקה
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  allocations EmploymentAllocation[]

  @@index([battalionId])
}

model EmploymentAllocation {
  id           String     @id @default(cuid())
  employmentId String
  employment   Employment @relation(fields: [employmentId], references: [id], onDelete: Cascade)
  companyId    String
  company      Holder     @relation("CompanyEmploymentAllocations", fields: [companyId], references: [id])
  date         DateTime   @db.Date
  allocated    Int        // כמות משובצים מתוכננת ליום זה

  @@unique([employmentId, companyId, date])
  @@index([employmentId])
}

// ===================== לוח זמינות (חופשות) =====================

model VacationBoard {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id])
  name        String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  assignees VacationAssignee[]
  entries   VacationEntry[]

  @@index([battalionId])
}

model VacationAssignee {
  id      String @id @default(cuid())
  boardId String
  board   VacationBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId  String
  user    AppUser @relation(fields: [userId], references: [id])

  @@unique([boardId, userId])
}

model VacationStatus {
  id          String @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id])
  name        String
  color       String   @default("#3b82f6")
  icon        String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)

  entries VacationEntry[]

  @@unique([battalionId, name])
}

model VacationEntry {
  id       String   @id @default(cuid())
  boardId  String
  board    VacationBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId   String
  user     AppUser @relation(fields: [userId], references: [id])
  date     DateTime @db.Date
  statusId String
  status   VacationStatus @relation(fields: [statusId], references: [id])

  @@unique([boardId, userId, date])
  @@index([boardId])
  @@index([userId])
}

// ===================== תפקידי שבצ"ק =====================

model DispatchRole {
  id            String @id @default(cuid())
  battalionId   String
  battalion     Battalion @relation("BattalionDispatchRoles", fields: [battalionId], references: [id], onDelete: Cascade)
  name          String
  icon          String  @default("🎖️")
  isDriver      Boolean @default(false)
  companyRoleId String?
  companyRole   CompanyRole? @relation("DispatchRoleCompanyRole", fields: [companyRoleId], references: [id], onDelete: SetNull)
  active        Boolean @default(true)
  sortOrder     Int     @default(0)
  createdAt     DateTime @default(now())

  templateSlots DispatchTemplateSoldier[]
  vehicleAssignmentSoldiers VehicleAssignmentSoldier[] @relation("VehicleAssignmentSoldierRole")

  @@unique([battalionId, name])
  @@index([battalionId])
}

// ===================== שבצ"ק קבוע (תבנית) =====================

model DispatchTemplate {
  id                  String @id @default(cuid())
  battalionId         String
  battalion           Battalion @relation("BattalionDispatchTemplates", fields: [battalionId], references: [id], onDelete: Cascade)
  name                String
  vehicleItemTypeId   String?
  vehicleItemType     ItemType? @relation("DispatchTemplateVehicleType", fields: [vehicleItemTypeId], references: [id], onDelete: SetNull)
  vehicleSerialUnitId String?
  vehicleSerialUnit   SerialUnit? @relation("DispatchTemplateVehicle", fields: [vehicleSerialUnitId], references: [id], onDelete: SetNull)
  round               Int?
  companyId           String?
  company             Holder? @relation("DispatchTemplateCompany", fields: [companyId], references: [id], onDelete: SetNull)
  active              Boolean @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById         String
  createdBy           AppUser @relation("DispatchTemplateCreatedBy", fields: [createdById], references: [id])

  slots               DispatchTemplateSoldier[]

  @@unique([battalionId, name])
  @@index([battalionId])
}

model DispatchTemplateSoldier {
  id             String @id @default(cuid())
  templateId     String
  template       DispatchTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dispatchRoleId String
  dispatchRole   DispatchRole @relation(fields: [dispatchRoleId], references: [id], onDelete: Cascade)
  soldierId      String?
  soldier        Soldier? @relation("SoldierDispatchTemplate", fields: [soldierId], references: [id], onDelete: SetNull)
  seatIndex      Int     @default(0)

  @@index([templateId])
  @@index([soldierId])
}

// ===================== הרשאות נהיגה =====================

model DrivingLicenseType {
  id          String @id @default(cuid())
  battalionId String
  battalion   Battalion @relation("BattalionDrivingLicenseTypes", fields: [battalionId], references: [id], onDelete: Cascade)
  name        String
  kind        String  @default("PERMIT") // LICENSE = רשיון נהיגה אזרחי · PERMIT = היתר נהיגה צבאי
  active      Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())

  soldierLicenses    SoldierDrivingLicense[]
  vehicleTypeLicenses VehicleTypeLicense[] @relation("LicenseTypeVehicleTypes")
  courseQuals         CourseTypeQualification[]

  @@unique([battalionId, name])
  @@index([battalionId])
}

// שיוך סוג רכב (ItemType) להרשאת נהיגה נדרשת
model VehicleTypeLicense {
  id            String @id @default(cuid())
  itemTypeId    String
  itemType      ItemType @relation("ItemTypeRequiredLicense", fields: [itemTypeId], references: [id], onDelete: Cascade)
  licenseTypeId String
  licenseType   DrivingLicenseType @relation("LicenseTypeVehicleTypes", fields: [licenseTypeId], references: [id], onDelete: Cascade)

  @@unique([itemTypeId, licenseTypeId])
}

model SoldierDrivingLicense {
  id            String @id @default(cuid())
  soldierId     String
  soldier       Soldier @relation("SoldierDrivingLicenses", fields: [soldierId], references: [id], onDelete: Cascade)
  licenseTypeId String
  licenseType   DrivingLicenseType @relation(fields: [licenseTypeId], references: [id], onDelete: Cascade)

  @@unique([soldierId, licenseTypeId])
  @@index([soldierId])
}

model CertificationType {
  id          String   @id @default(cuid())
  battalionId String
  battalion   Battalion @relation("BattalionCertificationTypes", fields: [battalionId], references: [id], onDelete: Cascade)
  name        String
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  soldiers    SoldierCertification[]
  courseQuals CourseTypeQualification[]

  @@unique([battalionId, name])
  @@index([battalionId])
}

model SoldierCertification {
  id                  String @id @default(cuid())
  soldierId           String
  soldier             Soldier @relation("SoldierCertifications", fields: [soldierId], references: [id], onDelete: Cascade)
  certificationTypeId String
  certificationType   CertificationType @relation(fields: [certificationTypeId], references: [id], onDelete: Cascade)

  @@unique([soldierId, certificationTypeId])
  @@index([soldierId])
}

// מספר ברזל / מיספור פנימי של המחסן לחייל — ייחודי בתוך המחסן (לתיוק מהיר בקלסר)
model WarehouseSoldierIndex {
  id          String  @id @default(cuid())
  battalionId String
  holderId    String
  holder      Holder  @relation("HolderSoldierIndex", fields: [holderId], references: [id], onDelete: Cascade)
  soldierId   String
  soldier     Soldier @relation("SoldierWarehouseIndex", fields: [soldierId], references: [id], onDelete: Cascade)
  number      Int
  createdAt   DateTime @default(now())

  @@unique([holderId, soldierId]) // לחייל מספר אחד למחסן
  @@unique([holderId, number])    // המספר ייחודי בתוך המחסן
  @@index([battalionId])
}

// ===================== הדרכות וקורסים (Trainings & Courses) =====================

enum CourseQualRole {
  PREREQ   // תנאי-קדם — נדרש כדי להתאים לקורס
  GRANT    // הקורס מקנה בסיום
}

enum CourseInstanceStatus {
  OPEN     // פתוח לשיבוץ
  CLOSED   // סגור לשיבוץ
  DONE     // הסתיים
}

enum CourseEnrollmentStatus {
  ENROLLED
  COMPLETED
  DROPPED
}

enum CourseRequestStatus {
  PENDING
  APPROVED
  REJECTED
  SCHEDULED
}

// קטלוג סוגי קורס — מנוהל ע"י קה"ד
model CourseType {
  id          String   @id @default(cuid())
  battalionId String
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  quals       CourseTypeQualification[]
  instances   CourseInstance[]
  requests    CourseRequest[]

  @@unique([battalionId, name])
  @@index([battalionId])
}

// תנאי-קדם / הקניה — הסמכה או רישיון נהיגה
model CourseTypeQualification {
  id                   String @id @default(cuid())
  courseTypeId         String
  courseType           CourseType @relation(fields: [courseTypeId], references: [id], onDelete: Cascade)
  role                 CourseQualRole
  certificationTypeId  String?
  certificationType    CertificationType? @relation(fields: [certificationTypeId], references: [id], onDelete: Cascade)
  drivingLicenseTypeId String?
  drivingLicenseType   DrivingLicenseType? @relation(fields: [drivingLicenseTypeId], references: [id], onDelete: Cascade)

  @@index([courseTypeId])
}

// מופע קורס — אירוע מתוזמן עם תאריך/מיקום/מכסות
model CourseInstance {
  id           String @id @default(cuid())
  battalionId  String
  courseTypeId String
  courseType   CourseType @relation(fields: [courseTypeId], references: [id], onDelete: Cascade)
  location     String?
  startDate    DateTime?
  hours        String?     // טקסט חופשי, למשל "08:00-16:00"
  bringItems   String?     // מה החייל צריך להביא
  contactName  String?
  contactPhone String?
  totalSlots   Int?        // סה"כ מקומות
  notes        String?
  status       CourseInstanceStatus @default(OPEN)
  active       Boolean @default(true)
  createdById  String?
  createdAt    DateTime @default(now())

  allocations  CourseAllocation[]
  enrollments  CourseEnrollment[]
  requests     CourseRequest[]

  @@index([battalionId])
  @@index([courseTypeId])
}

// מכסה פר-פלוגה למופע
model CourseAllocation {
  id               String @id @default(cuid())
  courseInstanceId String
  courseInstance   CourseInstance @relation(fields: [courseInstanceId], references: [id], onDelete: Cascade)
  companyId        String
  company          Holder @relation("HolderCourseAllocations", fields: [companyId], references: [id], onDelete: Cascade)
  slots            Int @default(0)

  @@unique([courseInstanceId, companyId])
  @@index([courseInstanceId])
}

// שיבוץ חייל למופע
model CourseEnrollment {
  id               String @id @default(cuid())
  battalionId      String
  courseInstanceId String
  courseInstance   CourseInstance @relation(fields: [courseInstanceId], references: [id], onDelete: Cascade)
  soldierId        String
  soldier          Soldier @relation("SoldierCourseEnrollments", fields: [soldierId], references: [id], onDelete: Cascade)
  status           CourseEnrollmentStatus @default(ENROLLED)
  enrolledById     String?
  enrolledAt       DateTime @default(now())
  completedAt      DateTime?

  @@unique([courseInstanceId, soldierId])
  @@index([courseInstanceId])
  @@index([soldierId])
  @@index([battalionId])
}

// בקשה לקורס — פר חייל, נכנסת לפול הממתינים
model CourseRequest {
  id               String @id @default(cuid())
  battalionId      String
  courseTypeId     String
  courseType       CourseType @relation(fields: [courseTypeId], references: [id], onDelete: Cascade)
  companyId        String?
  company          Holder? @relation("HolderCourseRequests", fields: [companyId], references: [id], onDelete: SetNull)
  soldierId        String?
  soldier          Soldier? @relation("SoldierCourseRequests", fields: [soldierId], references: [id], onDelete: SetNull)
  courseInstanceId String?
  courseInstance   CourseInstance? @relation(fields: [courseInstanceId], references: [id], onDelete: SetNull)
  note             String?
  status           CourseRequestStatus @default(PENDING)
  requestedById    String?
  requestedAt      DateTime @default(now())

  @@index([battalionId])
  @@index([courseTypeId])
}

// ===================== ניהול לוז =====================

enum ScheduleEventType {
  MUKDAM_MEASEF   // מקדים/מאסף
  PLUGATI         // לוז מפורט פלוגתי
}

model ScheduleEvent {
  id          String            @id @default(cuid())
  battalionId String
  battalion   Battalion         @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  name        String
  type        ScheduleEventType
  startDate   DateTime          @db.Date
  endDate     DateTime          @db.Date
  notes       String?
  active      Boolean           @default(true)
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  forces      ScheduleForce[]
  dayEntries  ScheduleDayEntry[]
  approvers   ScheduleApprover[]

  @@index([battalionId])
  @@index([battalionId, startDate])
}

model ScheduleApprover {
  id      String        @id @default(cuid())
  eventId String
  event   ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    AppUser       @relation("ScheduleApproverUser", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
}

model ScheduleForce {
  id          String        @id @default(cuid())
  eventId     String
  event       ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        AppUser       @relation("ScheduleForceUser", fields: [userId], references: [id])
  forceName   String
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  dayEntries  ScheduleDayEntry[]

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model ScheduleDayEntry {
  id            String        @id @default(cuid())
  eventId       String
  event         ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  forceId       String
  force         ScheduleForce @relation(fields: [forceId], references: [id], onDelete: Cascade)
  date          DateTime      @db.Date
  plannedTasks  String?
  actualTasks   String?
  plannedNotes  String?
  actualNotes   String?
  approved      Boolean       @default(false)
  approvedAt    DateTime?
  approvedById  String?
  updatedAt     DateTime      @updatedAt

  soldiers    ScheduleDaySoldier[]

  @@unique([forceId, date])
  @@index([eventId])
  @@index([forceId])
  @@index([date])
}

model ScheduleDaySoldier {
  id          String           @id @default(cuid())
  dayEntryId  String
  dayEntry    ScheduleDayEntry @relation(fields: [dayEntryId], references: [id], onDelete: Cascade)
  soldierId   String
  soldier     Soldier          @relation("SoldierScheduleDay", fields: [soldierId], references: [id], onDelete: Cascade)
  phase       String           @default("planned") // "planned" | "actual"

  @@unique([dayEntryId, soldierId, phase])
  @@index([dayEntryId])
  @@index([soldierId])
}

// ===================== ימ"ח — מחסן פלוגתי =====================

// מחסן ימ"ח — פלוגה יכולה להחזיק 1+ מחסנים עם מידוף עצמאי
model CompanyWarehouse {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation("BattalionCompanyWarehouses", fields: [battalionId], references: [id], onDelete: Cascade)
  holderId    String
  holder      Holder    @relation("HolderCompanyWarehouses", fields: [holderId], references: [id], onDelete: Cascade)
  name        String
  notes       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  shelves CompanyShelf[]

  @@unique([holderId, name])
  @@index([battalionId])
  @@index([holderId])
}

// מדף בתוך מחסן ימ"ח — עמודה × שורה + תווית
model CompanyShelf {
  id          String           @id @default(cuid())
  warehouseId String
  warehouse   CompanyWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  column      String
  row         String
  label       String?

  items            CompanyShelfItem[]
  operationalKits  OperationalKit[]   @relation("OpKitShelf")
  storedSerialUnits SerialUnit[]      @relation("StoredOnShelf")

  @@unique([warehouseId, column, row])
  @@index([warehouseId])
}

// שיוך פריט למדף (פריט יכול להיות על 2+ מדפים)
model CompanyShelfItem {
  id         String       @id @default(cuid())
  shelfId    String
  shelf      CompanyShelf @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  itemTypeId String
  itemType   ItemType     @relation("ItemTypeOnShelf", fields: [itemTypeId], references: [id], onDelete: Cascade)
  quantity   Int          @default(1)
  notes      String?

  @@unique([shelfId, itemTypeId])
  @@index([shelfId])
  @@index([itemTypeId])
}

// ארגז מבצעי — ערכה פלוגתית שחוזרת כיחידה (≠ ערכת החתמה)
model OperationalKit {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation("BattalionOpKits", fields: [battalionId], references: [id], onDelete: Cascade)
  holderId    String
  holder      Holder    @relation("HolderOpKits", fields: [holderId], references: [id], onDelete: Cascade)
  kitNumber   String?
  name        String
  shelfId     String?
  shelf       CompanyShelf? @relation("OpKitShelf", fields: [shelfId], references: [id], onDelete: SetNull)
  equipmentLocationId String?
  equipmentLocation   EquipmentLocation? @relation("OpKitEquipmentLocation", fields: [equipmentLocationId], references: [id], onDelete: SetNull)
  assignedSoldierId String?
  assignedSoldier   Soldier? @relation("SoldierOpKits", fields: [assignedSoldierId], references: [id], onDelete: SetNull)
  // סטטוס: STORED=על המדף, ISSUED=אצל החייל
  status      String    @default("STORED") // "STORED" | "ISSUED"
  notes       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items OperationalKitItem[]
  ymachGaps YmachGap[] @relation("OpKitYmachGaps")

  @@unique([holderId, name])
  @@index([battalionId])
  @@index([holderId])
  @@index([assignedSoldierId])
  @@index([equipmentLocationId])
}

// פער ימ"ח — פריט שלא הוחזר באפסון
model YmachGap {
  id            String    @id @default(cuid())
  battalionId   String
  battalion     Battalion @relation("BattalionYmachGaps", fields: [battalionId], references: [id], onDelete: Cascade)
  holderId      String
  holder        Holder    @relation("HolderYmachGaps", fields: [holderId], references: [id], onDelete: Cascade)
  soldierId     String
  soldier       Soldier   @relation("SoldierYmachGaps", fields: [soldierId], references: [id], onDelete: Cascade)
  serialUnitId  String?
  serialUnit    SerialUnit? @relation("YmachGapSerialUnit", fields: [serialUnitId], references: [id], onDelete: SetNull)
  itemTypeId    String
  itemType      ItemType  @relation("YmachGapItemType", fields: [itemTypeId], references: [id], onDelete: Cascade)
  operationalKitId String?
  operationalKit   OperationalKit? @relation("OpKitYmachGaps", fields: [operationalKitId], references: [id], onDelete: SetNull)
  quantity      Int       @default(1)
  reason        String    // "LOST" | "BROKEN" | "IN_USE" | "OTHER"
  reasonText    String?
  status        String    @default("OPEN") // "OPEN" | "RESOLVED"
  resolvedAt    DateTime?
  resolvedById  String?
  createdAt     DateTime  @default(now())
  createdById   String?

  @@index([battalionId])
  @@index([holderId])
  @@index([soldierId])
  @@index([status])
}

// פריט בתוך ארגז מבצעי
model OperationalKitItem {
  id         String         @id @default(cuid())
  kitId      String
  kit        OperationalKit @relation(fields: [kitId], references: [id], onDelete: Cascade)
  itemTypeId String
  itemType   ItemType       @relation("ItemTypeInOpKit", fields: [itemTypeId], references: [id], onDelete: Cascade)
  quantity   Int            @default(1)

  @@unique([kitId, itemTypeId])
  @@index([kitId])
  @@index([itemTypeId])
}

// ===================== אימות ציוד (Verification) =====================

enum VerificationStatus {
  PENDING
  SENT
  CONFIRMED
  DENIED
  NO_RESPONSE
}

enum VerificationMode {
  CONFIRM          // אישור קיום: נמצא / לא נמצא
  SERIAL_ENTRY     // הקשת מספר סריאלי (המערכת משווה)
  LOCATION         // בחירת מיקום מרשימה מוגדרת
  QUANTITY_CONFIRM // אישור כמות (רואה כמות צפויה, מאשר/מתקן)
  BLIND_COUNT      // ספירה עיוורת (מקליד כמות ללא מידע מקדים)
  BATCH            // אצווה: מאשר קבוצת פריטים יחד
}

// בקשת אימות — לחייל או לפלוגה/מחסן
model VerificationRequest {
  id            String   @id @default(cuid())
  battalionId   String
  battalion     Battalion @relation("BattalionVerifications", fields: [battalionId], references: [id], onDelete: Cascade)
  sessionId     String
  session       CountSession @relation("SessionVerifications", fields: [sessionId], references: [id], onDelete: Cascade)
  soldierId     String?
  soldier       Soldier?  @relation("SoldierVerifications", fields: [soldierId], references: [id], onDelete: Cascade)
  holderId      String?
  holder        Holder?   @relation("HolderVerifications", fields: [holderId], references: [id], onDelete: Cascade)
  mode          VerificationMode @default(CONFIRM)
  token         String   @unique @default(nanoid(24))
  sentAt        DateTime?
  sentVia       String?  // "WHATSAPP" | "TELEGRAM"
  respondedAt   DateTime?
  createdAt     DateTime @default(now())

  items VerificationItem[]

  @@index([sessionId])
  @@index([soldierId])
  @@index([holderId])
  @@index([battalionId])
}

// פריט באימות
model VerificationItem {
  id              String   @id @default(cuid())
  requestId       String
  request         VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  serialUnitId    String?
  serialUnit      SerialUnit? @relation("SerialUnitVerifications", fields: [serialUnitId], references: [id], onDelete: Cascade)
  itemTypeName    String
  serialNumber    String?
  status          VerificationStatus @default(PENDING)
  photoData       String?
  respondedAt     DateTime?
  note            String?
  // שדות לאימות כמות
  expectedQuantity  Int?
  reportedQuantity  Int?
  // שדות לאימות מיקום / הקשת מק"ט
  reportedSerial    String?
  reportedLocation  String?
  // שדות לאימות תוקף — expectedExpiry = התאריך הידוע במערכת; reportedExpiry = מה שדווח
  expectedExpiry    DateTime?
  reportedExpiry    DateTime?
  // קישור לפריט — לסנכרון תגובת החייל חזרה ל-CountLine + יצירת Discrepancy
  itemTypeId        String?

  @@index([requestId])
}

// טוקן חד-פעמי לשבצ"ק מלינק חיצוני (ללא צורך בהתחברות)
model DispatchToken {
  id          String   @id @default(cuid())
  token       String   @unique
  battalionId String
  battalion   Battalion @relation("BattalionDispatchTokens", fields: [battalionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  maxUses     Int      @default(10)
  useCount    Int      @default(0)

  @@index([token])
  @@index([battalionId])
}

// ===================== עזרה למפקדים (Support) =====================

// הגדרות תמיכה גלובליות (אדמין-על) — singleton
model AppConfig {
  id                     String  @id @default("singleton")
  supportWhatsappEnabled Boolean @default(false)
  supportWhatsappNumber  String? // מספר בפורמט בינ"ל ללא + (למשל 972501234567)
  supportMessage         String? // טקסט פתיחה לוואטסאפ
  updatedAt              DateTime @updatedAt
}

// שאלה/צורך שמפקד מעלה
model SupportQuestion {
  id           String   @id @default(cuid())
  battalionId  String
  battalion    Battalion @relation("BattalionSupport", fields: [battalionId], references: [id], onDelete: Cascade)
  askedById    String?
  askedByName  String
  category     String?  // "שאלה" | "תקלה" | "צורך/בקשה"
  question     String
  status       String   @default("OPEN") // OPEN | ANSWERED
  answer       String?
  answeredById String?
  answeredAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([battalionId, status])
}

/**
 * ריצת גיבוי — תיעוד כל גיבוי אוטומטי (פעמיים ביום). גלובלי (לא פר-גדוד).
 * data מכיל snapshot JSON כ-fallback ב-DB; מנוקה לריצות ישנות (נשמר רק לאחרונות).
 */
model BackupRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  status    String   // "OK" | "FAIL"
  target    String   // "BLOB" | "DB"
  sizeBytes Int      @default(0)
  rowCounts Json?    // { SerialUnit: 129, Signature: 230, ... }
  blobUrl   String?  // URL אם הועלה ל-Vercel Blob
  data      String?  // snapshot JSON (fallback ב-DB)
  error     String?

  @@index([createdAt])
}

/**
 * אתגר חיבור-בוט דו-שלבי (זמני): החייל הקליד מ.א, וממתין לשיתוף מספר טלפון לאימות.
 * מונע חטיפת זהות — נדרשים גם מ.א וגם המכשיר עם המספר האמיתי. מתנקה אחרי אימות/תפוגה.
 */
model TelegramBindChallenge {
  id             String   @id @default(cuid())
  battalionId    String
  chatId         String
  personalNumber String
  createdAt      DateTime @default(now())

  @@unique([battalionId, chatId])
  @@index([createdAt])
}

/** מצב "ממתין לתמונה" בבוט — החייל בחר סוג צילום (רישיון אזרחי/צבאי) והתמונה הבאה תישמר לשם. */
model TelegramPhotoRequest {
  battalionId String
  chatId      String
  target      String // civFront / civBack / milFront
  createdAt   DateTime @default(now())

  @@id([battalionId, chatId])
}

/** חריגת חלון-דיווח נוכחות לתאריך ספציפי (למשל לפני חג — לדווח כמה ימים קדימה). */
model AttendanceReportOverride {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date // היום שבו מדווחים
  daysForward Int       // כמה ימים קדימה מותר לדווח מהתאריך הזה
  note        String?
  createdAt   DateTime  @default(now())

  @@unique([battalionId, date])
  @@index([battalionId])
}

/**
 * נוכחות "מי מדווח עכשיו" — לתיאום בין 2 נאמני כ"א על אותה קבוצה (scope+יום).
 * לא נעילה קשיחה: שורה פר-נאמן, heartbeat מרענן lastActiveAt. אם נאמן אחר פעיל
 * לאחרונה — מוצגת אזהרה כדי שלא יעבדו במקביל וידרסו. lastSubmitAt = מתי דיווח לאחרונה.
 */
model AttendanceReporterPresence {
  id           String   @id @default(cuid())
  battalionId  String
  scopeKey     String   // squadId אם משויך למחלקה, אחרת companyId
  date         DateTime @db.Date
  reporterId   String   // מזהה החייל-נאמן
  reporterName String
  lastActiveAt DateTime @updatedAt
  lastSubmitAt DateTime?

  @@unique([scopeKey, date, reporterId])
  @@index([scopeKey, date])
  @@index([battalionId, date])
}

/** כרטיס דלק שנמשך ע"י חייל — מעקב מי מחזיק, מספר כרטיס, מתי נמשך והוחזר. */
model VehicleFuelCard {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  soldierId   String
  soldier     Soldier   @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  cardNumber  String    // מספר הכרטיס
  checkoutAt  DateTime  @default(now()) // תאריך משיכה
  signatureData String?  // חתימת החייל על הקבלה (data URL) — נחתם על המובייל של קצין הרכב
  signerName    String?  // שם החותם
  signedAt      DateTime? // מתי נחתם
  signLinkSentAt DateTime? // מתי נשלחה בקשת חתימה מרחוק (בוט/וואטסאפ) — למעקב סטטוס ושליחה חוזרת
  returnedAt  DateTime? // תאריך החזרה (null = פתוח אצל החייל)
  note        String?
  createdById String?
  createdAt   DateTime  @default(now())

  @@index([battalionId, returnedAt])
  @@index([soldierId])
}

/** קישור שימושי לקצין רכב (למשל מוסך/צמיגים) — מוצג לחייל בבוט לפי שם, הלינק שתול. */
model VehicleLink {
  id               String    @id @default(cuid())
  battalionId      String
  battalion        Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  name             String    // שם הקישור (מוצג)
  url              String    // הלינק עצמו (שתול)
  visibleToSoldier Boolean   @default(true) // האם להציג לחייל בבוט
  sortOrder        Int       @default(0)
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())

  @@index([battalionId])
}

/** תוכנית טיפולים לרכב (בבעלות קצין רכב) — תאריך הטיפול הבא + פרטי המוסך. אחד לרכב. */
model VehicleMaintenance {
  id                  String     @id @default(cuid())
  battalionId         String
  battalion           Battalion  @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  vehicleSerialUnitId String     @unique
  vehicleSerialUnit   SerialUnit @relation("VehicleMaintenanceUnit", fields: [vehicleSerialUnitId], references: [id], onDelete: Cascade)
  nextDate            DateTime?  // יום הטיפול הבא
  serviceType         String?    // סוג הטיפול (למשל: טיפול 10,000 ק"מ)
  location            String?    // מיקום הטיפול (מוסך)
  hours               String?    // שעות
  contactName         String?    // איש קשר
  contactPhone        String?    // טלפון איש קשר
  notes               String?
  lastServiceDate     DateTime?  // טיפול אחרון שבוצע
  reminderSentFor     DateTime?  // עבור איזה nextDate כבר נשלחה תזכורת (מניעת כפילות)
  createdById         String?
  updatedById         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([battalionId, nextDate])
}

/**
 * רישום הודעות/תזכורות בוט מתוזמנות — מסך שליטה מרכזי.
 * key ייחודי לגדוד; enabled + daysBefore + recipients קובעים אם/מתי/למי לשלוח.
 */
model BotNotificationRule {
  id           String    @id @default(cuid())
  battalionId  String
  battalion    Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  key          String    // מזהה קבוע: maintenance-reminder / attendance-morning / counts-overdue ...
  name         String    // שם תצוגה
  description  String?    // מה נשלח
  enabled      Boolean   @default(true)
  daysBefore   Int       @default(1) // כמה ימים לפני (לתזכורות מבוססות-תאריך)
  recipients   String    @default("") // תגיות נמענים מופרדות בפסיק (vehicle-officer,signed-holder,...)
  updatedById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([battalionId, key])
  @@index([battalionId])
}

/** תיק תקלה/טיפול לרכב — מספר תקלה רץ + מחזור סטטוסים (תקול→משיכה→טיפול→החזרה). */
model VehicleFault {
  id                  String     @id @default(cuid())
  battalionId         String
  battalion           Battalion  @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  faultNumber         Int        // מספר תקלה רץ בגדוד
  vehicleSerialUnitId String
  vehicleSerialUnit   SerialUnit @relation("VehicleFaultUnit", fields: [vehicleSerialUnitId], references: [id], onDelete: Cascade)
  categoryId          String?
  category            VehicleFaultCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description         String     // תיאור התקלה
  stage              String     @default("reported") // מפתח השלב הנוכחי במחזור
  originHolderId     String?    // הפלוגה שהרכב חזר אליה כשהתיק נסגר (לפני המשיכה לטנא)
  atTana             Boolean    @default(false) // האם הרכב עבר פיזית לטנא במסגרת התיק
  openedById         String?
  openedAt           DateTime   @default(now())
  closedAt           DateTime?  // מלא כשהתקלה נסגרה (נמסר לפלוגה)
  events             VehicleFaultEvent[]

  @@unique([battalionId, faultNumber])
  @@index([battalionId, closedAt])
  @@index([vehicleSerialUnitId])
}

/** קטגוריית תקלת רכב — טבלה ניתנת לעריכה (מגיעה עם ברירות מחדל + "אחר"). */
model VehicleFaultCategory {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  faults      VehicleFault[]

  @@unique([battalionId, name])
  @@index([battalionId])
}

/** אירוע בתיק התקלה — מעבר שלב או הערה. */
model VehicleFaultEvent {
  id          String       @id @default(cuid())
  faultId     String
  fault       VehicleFault @relation(fields: [faultId], references: [id], onDelete: Cascade)
  stage       String       // השלב אליו עברו, או "note" להערה בלבד
  note        String?
  createdById String?
  createdByName String?
  createdAt   DateTime     @default(now())

  @@index([faultId])
}

// ===== סבב בדיקות נשקייה =====
model ArmoryChecklistItem {
  id          String    @id @default(cuid())
  battalionId String
  battalion   Battalion  @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  label       String
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@index([battalionId])
}

model ArmoryInspection {
  id                 String    @id @default(cuid())
  battalionId        String
  battalion          Battalion  @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  holderId           String?    // מחסן הארמון (holder)
  scheduledAt        DateTime   // מועד הבדיקה
  inspectorSoldierId String?    // המפקד הבודק (חייל במערכת) — או שם חופשי
  inspectorName      String?
  status             String     @default("SCHEDULED") // SCHEDULED | COMPLETED
  overallOk          Boolean?   // האם כל הסעיפים תקינים
  signatureData      String?    // חתימת המפקד (dataURL)
  signerName         String?
  notes              String?
  completedAt        DateTime?
  createdById        String?
  createdAt          DateTime   @default(now())
  items              ArmoryInspectionItem[]

  @@index([battalionId])
  @@index([status])
}

model ArmoryInspectionItem {
  id           String   @id @default(cuid())
  inspectionId String
  inspection   ArmoryInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  label        String
  ok           Boolean?
  note         String?
  sortOrder    Int      @default(0)

  @@index([inspectionId])
}

// ===== היררכיית יחידה + דרישות לרמה הממונה (גדוד → חטיבה) =====
enum UnitLevel {
  BRIGADE   // חטיבה
  BATTALION // גדוד
}

enum RequestType {
  CONSTRUCTION // בינוי
  TRANSPORT    // הובלה
  SUPPLY       // הספקה
  FUEL         // דלקים
  FUEL_CARDS   // כרטיסי דלק
  MEDICAL      // רפואה
  TRAINING     // הדרכות/קורסים
  OTHER        // אחר
}

enum RequestPriority {
  ROUTINE     // רגיל
  URGENT      // דחוף
  OPERATIONAL // מבצעי
}

enum RequestStatus {
  DRAFT             // טיוטה
  PENDING_APPROVAL  // ממתין לאישור מפקד (בגדוד)
  IN_PROGRESS       // בטיפול החטיבה (קבלה אוטומטית בהסלמה)
  NEEDS_INFO        // דרוש מידע — הוחזר לגדוד
  RESOLVED          // נפתר
  REJECTED          // נדחה
  CANCELLED         // בוטל
}

/** דרישה/פנייה מיחידה לרמה הממונה (גדוד→חטיבה). openerUnit=battalion, targetUnit=parent. */
model Request {
  id           String          @id @default(cuid())
  battalionId  String          // היחידה הפותחת (גדוד)
  battalion    Battalion       @relation("RequestOpener", fields: [battalionId], references: [id], onDelete: Cascade)
  targetUnitId String          // היחידה הממונה שאליה מופנית הדרישה (חטיבה)
  targetUnit   Battalion       @relation("RequestTarget", fields: [targetUnitId], references: [id])
  companyId    String?         // אם פלוגה פתחה
  type         RequestType
  title        String
  description  String?
  data         Json?           // ערכי שדות דינמיים פר-סוג (key→value) — מבקש + מטפל
  priority     RequestPriority @default(ROUTINE)
  status       RequestStatus   @default(PENDING_APPROVAL)
  openedById   String?         // AppUser שפתח
  openedByName String?
  approvedById String?         // מפקד שאישר והסלים
  assignedToId String?         // בעל תפקיד בחטיבה שמטפל
  assignedName String?
  createdAt    DateTime        @default(now())
  escalatedAt  DateTime?       // מתי הוסלם לחטיבה
  resolvedAt   DateTime?
  updates      RequestUpdate[]
  transportParties TransportParty[]

  @@index([battalionId])
  @@index([targetUnitId, status])
}

/** שרשור עדכונים/דיווחי-טיפול על דרישה (thread). */
model RequestUpdate {
  id         String        @id @default(cuid())
  requestId  String
  request    Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId   String?
  authorName String?
  text       String
  statusFrom RequestStatus?
  statusTo   RequestStatus?
  createdAt  DateTime      @default(now())

  @@index([requestId])
}

/** הקצאת בעל-תפקיד בחטיבה לסוג דרישה (מלכ"א מנהל). משתמש יכול לקבל כמה סוגים. */
model RequestTypeHandler {
  id            String      @id @default(cuid())
  brigadeUnitId String      // יחידת החטיבה
  type          RequestType
  userId        String      // AppUser — בעל התפקיד
  createdAt     DateTime    @default(now())

  @@unique([brigadeUnitId, type, userId])
  @@index([brigadeUnitId])
  @@index([userId])
}

/** אחראי-תחום ברמת הגדוד (צד המבקש) — פר-סוג. חייל במערכת (userId) או חייל
 *  ללא חשבון שעובד דרך הבוט עם טוקן. מקבל התראות על שינויים בדרישות מהסוג שלו. */
model RequestResponsible {
  id          String      @id @default(cuid())
  battalionId String      // הגדוד המבקש
  type        RequestType
  userId      String?     // AppUser — אם חייל במערכת
  name        String      // שם לתצוגה (חובה גם ללא חשבון)
  phone       String?
  token       String      @unique @default(nanoid(24)) // קישור בוט לחייל ללא חשבון
  chatId      String?     // מזהה צ'אט טלגרם לאחר binding
  createdAt   DateTime    @default(now())

  @@index([battalionId, type])
  @@index([token])
}

/** צד בהובלה (מעמיס/פורק) — מקבל קישור בוט אישי לעדכון מה הועמס / שהכל הגיע. */
model TransportParty {
  id         String        @id @default(cuid())
  requestId  String
  request    Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  role       TransportRole
  name       String?       // שם איש הקשר (מהדרישה)
  token      String        @unique @default(nanoid(24))
  chatId     String?       // מזהה צ'אט טלגרם לאחר binding
  reportText String?       // הדיווח החופשי (מה הועמס / אישור הגעה)
  reportedAt DateTime?
  createdAt  DateTime      @default(now())

  @@unique([requestId, role])
  @@index([token])
}

enum TransportRole {
  LOADER   // מעמיס
  UNLOADER // פורק
}

/** מאגר כרטיסי דלק ברמת החטיבה — נטען ע"י המלכ"א, מוקצה לגדוד ונחתם ע"י קצין רכב/מפקד. */
model BrigadeFuelCard {
  id             String                @id @default(cuid())
  brigadeUnitId  String                // יחידת החטיבה (בעלים)
  cardNumber     String                // מספר הכרטיס
  label          String?               // הערה / סוג דלק
  status         BrigadeFuelCardStatus @default(AVAILABLE)
  allocatedBattalionId String?         // הגדוד שהוקצה לו
  allocatedName        String?         // שם הגדוד (cache לתצוגה)
  allocatedAt          DateTime?
  signedByName     String?             // שם החותם (קצין רכב / מפקד)
  signedByPersonal String?             // מ"א החותם
  signatureData    String?             // חתימה דיגיטלית (data URL)
  signedAt         DateTime?
  token          String                @unique @default(nanoid(24)) // קישור חתימה מרחוק / בוט
  createdAt      DateTime              @default(now())

  @@unique([brigadeUnitId, cardNumber])
  @@index([brigadeUnitId, status])
  @@index([allocatedBattalionId, status])
  @@index([token])
}

enum BrigadeFuelCardStatus {
  AVAILABLE // במאגר החטיבה, לא הוקצה
  ALLOCATED // הוקצה לגדוד, ממתין לחתימה
  SIGNED    // נחתם ע"י הגדוד
}

// ===== ניהול משמרות / משימות (שמירה, ניקיונות, תורני מטבח...) =====
enum DutyVisibility {
  ALL       // כל המשתמשים בגדוד רואים את הלוח
  SELECTED  // רק משתמשים שנבחרו
}

/** לוח משימות — יוזם מקים, מגדיר טווח/שעות/נראוּת, ואחרים משבצים. */
model DutyBoard {
  id           String         @id @default(cuid())
  battalionId  String
  battalion    Battalion      @relation(fields: [battalionId], references: [id], onDelete: Cascade)
  name         String         // "שמירה" / "ניקיונות" / "תורני מטבח"
  visibility   DutyVisibility @default(ALL)
  fromDate     DateTime?      @db.Date
  toDate       DateTime?      @db.Date
  defaultStart String?        // שעת התחלה ברירת מחדל "20:00"
  defaultEnd   String?        // שעת סיום "22:00"
  notes        String?
  active       Boolean        @default(true)
  createdById  String?
  createdByName String?
  createdAt    DateTime       @default(now())
  slots        DutySlot[]
  viewers      DutyBoardViewer[]

  @@index([battalionId])
}

/** מי רשאי לראות לוח (כאשר visibility=SELECTED). */
model DutyBoardViewer {
  id      String    @id @default(cuid())
  boardId String
  board   DutyBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId  String    // AppUser

  @@unique([boardId, userId])
  @@index([userId])
}

/** משבצת בלוח — תאריך + שעות (או יומי), פלוגה/מחלקה וחייל אחראי למילוי. */
model DutySlot {
  id                   String    @id @default(cuid())
  boardId              String
  board                DutyBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  date                 DateTime  @db.Date
  startTime            String?   // "20:00" — null = יומי
  endTime              String?
  label                String?   // "עמדה 1" / תיאור
  companyId            String?   // פלוגה/מסגרת אחראית (Holder)
  squadId              String?   // מחלקה אחראית
  responsibleSoldierId String?   // חייל אחראי למילוי
  capacity             Int       @default(1) // כמה חיילים נדרשים במשבצת
  createdById          String?
  createdAt            DateTime  @default(now())
  assignments          DutyAssignment[]

  @@index([boardId, date])
}

/** חייל ששובץ למשבצת — מקבל התראה. */
model DutyAssignment {
  id             String   @id @default(cuid())
  slotId         String
  slot           DutySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  soldierId      String
  assignedById   String?
  assignedByName String?
  notifiedAt     DateTime?
  createdAt      DateTime @default(now())

  @@unique([slotId, soldierId])
  @@index([soldierId])
}

// ===== שדות דינמיים + הגדרות פר-סוג-דרישה (מנוע טפסים) =====
enum RequestFieldSide {
  REQUESTER
  HANDLER
}

enum RequestFieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  DATE
  TIME
  CONTACT
}

/** הגדרת סוג-דרישה פר-חטיבה — דגל אישור-מפמ + חלון בקשה. */
model RequestTypeConfig {
  id            String      @id @default(cuid())
  brigadeUnitId String
  type          RequestType
  requiresApproval Boolean  @default(false)
  requestDays   String?     // ימי בקשה מותרים (מלל, למשל "א,ג,ה")
  requestHours  String?     // שעות בקשה "08:00-12:00"
  supplyTiming  String?     // מתי אספקה (לא חובה)

  @@unique([brigadeUnitId, type])
}

/** הגדרת שדה דינמי בטופס פר-סוג (צד מבקש/מטפל). SELECT → options ניתנות לעריכה. */
model RequestFieldDef {
  id            String           @id @default(cuid())
  brigadeUnitId String
  type          RequestType
  side          RequestFieldSide
  fieldKey      String           // מזהה ייחודי (slug)
  label         String
  fieldType     RequestFieldType @default(TEXT)
  options       String[]         @default([]) // ל-SELECT
  required      Boolean          @default(false)
  sortOrder     Int              @default(0)
  active        Boolean          @default(true)

  @@index([brigadeUnitId, type, side])
}
